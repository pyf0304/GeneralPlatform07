            List<clsUsersEN> arrUsersObjLst = clsUsersBL.GetUsersObjList(strWhereCond);
            return arrUsersObjLst;
        }

        /// <summary>
        /// 获取当前表满足条件的第一条记录的关键字值
        /// </summary>
        /// <param name="strCondition">条件串</param>
        /// <returns>返回的第一条记录的关键字值</returns>
        [WebMethod]
        public string Users_GetFirstID_S(string strCondition)
        {
            string strUserId;
            try
            {
                strUserId = clsUsersBL.GetFirstID_S(strCondition);
                return strUserId;
            }
            catch (Exception objException)
            {
                throw new Exception("获取First关键字出错！\r\n" + objException.Message);
            }
        }

        /// <summary>
        /// 获取当前表满足条件的第一条记录的对象
        /// </summary>
        /// <param name="strCondition">条件串</param>
        /// <returns>返回的第一条记录的对象</returns>
        [WebMethod]
        public clsUsersEN Users_GetFirstUsers_S(string strCondition)
        {
            try
            {
                clsUsersEN objUsersEN = clsUsersBL.GetFirstUsers_S(strCondition);
                return objUsersEN;
            }
            catch (Exception objException)
            {
                throw new Exception("获取First记录对象出错！\r\n" + objException.Message);
            }
        }

        [WebMethod]
