 /// <summary>
 /// 根据关键字获取相关名称, 从缓存的对象列表中获取.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecNameByKey_Cache)
 /// </summary>
 /// <param name = "strDataBaseTypeId">所给的关键字</param>
 /// <returns>根据关键字获取的名称</returns>
public static string GetDataBaseTypeNameByDataBaseTypeId_Cache(string strDataBaseTypeId)
{
if (string.IsNullOrEmpty(strDataBaseTypeId) == true) return "";
string strWhereCond = string.Format("1 = 1 order by DataBaseTypeId");
if (arrDataBaseTypeObjLst_Cache == null)
{
arrDataBaseTypeObjLst_Cache = clsDataBaseTypeWS.GetDataBaseTypeObjList(strWhereCond);
}
int intStart = 0;
int intEnd = arrDataBaseTypeObjLst_Cache.Count - 1;
int intMid = 0;
clsDataBaseTypeEN objDataBaseTypeEN = null;
while (intEnd >= intStart)
{
intMid = (intStart + intEnd) / 2;
objDataBaseTypeEN = arrDataBaseTypeObjLst_Cache[intMid];
if (objDataBaseTypeEN.DataBaseTypeId == strDataBaseTypeId)
{
intFindFailCount = 0;
return objDataBaseTypeEN.DataBaseTypeName;
}
else if (objDataBaseTypeEN.DataBaseTypeId.CompareTo(strDataBaseTypeId) > 0)
{
intEnd = intMid - 1;
}
else
{
intStart = intMid + 1;
}
}
intFindFailCount++;
// 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
arrDataBaseTypeObjLst_Cache = null;
if (intFindFailCount == 1) return GetDataBaseTypeNameByDataBaseTypeId_Cache(strDataBaseTypeId);
string strErrMsgForGetObjById = string.Format("在DataBaseType对象缓存列表中,找不到记录[DataBaseTypeId = {0}][intFindFailCount = {1}](函数:GetDataBaseTypeNameByDataBaseTypeId_Cache)", strDataBaseTypeId, intFindFailCount);
if (objDataBaseTypeEN != null)
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objDataBaseTypeEN.DataBaseTypeId, intMid);
}
else
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
}
clsGeneralTab2.LogErrorS2("clsDataBaseTypeBL", "GetDataBaseTypeNameByDataBaseTypeId_Cache", strErrMsgForGetObjById, "", "");
throw new Exception(strErrMsgForGetObjById);
}

