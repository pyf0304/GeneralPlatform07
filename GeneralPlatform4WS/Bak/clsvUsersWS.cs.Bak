        /// <summary>
        /// 根据关键字获取相关对象, 从缓存的对象列表中获取.
        /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecObjByKey_Cache)
        /// </summary>
        /// <param name = "strUserId">所给的关键字</param>
        /// <returns>根据关键字获取的对象</returns>
        public static clsvUsersEN GetvUsersObjByUserId_Cache(string strUserId)
        {
            if (string.IsNullOrEmpty(strUserId) == true) return null;
            string strWhereCond = string.Format("1 = 1 order by UserId");
            if (arrvUsersObjLst_Cache == null)
            {
                arrvUsersObjLst_Cache = clsvUsersWS.GetvUsersObjList(strWhereCond);
            }
            int intStart = 0;
            int intEnd = arrvUsersObjLst_Cache.Count - 1;
            int intMid = 0;
            clsvUsersEN objvUsersEN = null;
            while (intEnd >= intStart)
            {
                intMid = (intStart + intEnd) / 2;
                objvUsersEN = arrvUsersObjLst_Cache[intMid];
                if (objvUsersEN.UserId == strUserId)
                {
                    intFindFailCount = 0;
                    return objvUsersEN;
                }
                else if (objvUsersEN.UserId.CompareTo(strUserId) > 0)
                {
                    intEnd = intMid - 1;
                }
                else
                {
                    intStart = intMid + 1;
                }
            }
            intFindFailCount++;
            // 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
            arrvUsersObjLst_Cache = null;
            if (intFindFailCount == 1) return GetvUsersObjByUserId_Cache(strUserId);
            string strErrMsgForGetObjById = string.Format("在vUsers对象缓存列表中,找不到记录[UserId = {0}][intFindFailCount = {1}](函数:GetvUsersObjByUserId_Cache)", strUserId, intFindFailCount);
            if (objvUsersEN != null)
            {
                strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objvUsersEN.UserId, intMid);
            }
            else
            {
                strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
            }
            clsGeneralTab2.LogErrorS2("clsvUsersBL", "GetvUsersObjByUserId_Cache", strErrMsgForGetObjById, "", "");
            throw new Exception(strErrMsgForGetObjById);
        }

        public static List<clsvUsersEN> GetvUsersObjList(string strWhereCond)
        {
            List<clsvUsersEN> arrObjList = new List<clsvUsersEN>();
            System.Data.DataTable objDT = null;
            objDT = GetDataTable_vUsersWs(strWhereCond);
            if (objDT.Rows.Count == 0)
            {
                objDT = null;
                return arrObjList;
            }
            foreach (DataRow objRow in objDT.Rows)
            {
                clsvUsersEN objvUsersEN = new clsvUsersEN();
                objvUsersEN.UserId = objRow["UserId"].ToString().Trim(); //用户ID
                objvUsersEN.UserName = objRow["UserName"].ToString().Trim(); //用户名
                objvUsersEN.DepartmentId = objRow["DepartmentId"].ToString().Trim(); //部门Id
                objvUsersEN.DepartmentName = objRow["DepartmentName"].ToString().Trim(); //部门名
                objvUsersEN.UpDepartmentId = objRow["UpDepartmentId"].ToString().Trim(); //所属部门号
                objvUsersEN.DepartmentAbbrName = objRow["DepartmentAbbrName"].ToString().Trim(); //名称缩写
                objvUsersEN.UpDepartmentName = objRow["UpDepartmentName"].ToString().Trim(); //上级部门
                objvUsersEN.SubjectTypeName = objRow["SubjectTypeName"].ToString().Trim(); //学科类型
                objvUsersEN.DepartmentTypeId = objRow["DepartmentTypeId"].ToString().Trim(); //部门类型ID
                objvUsersEN.DepartmentTypeName = objRow["DepartmentTypeName"].ToString().Trim(); //部门类型名
                objvUsersEN.UserStateId = objRow["UserStateId"].ToString().Trim(); //用户状态Id
                objvUsersEN.UserStateName = objRow["UserStateName"].ToString().Trim(); //用户状态名
                objvUsersEN.EffectiveDate = objRow["EffectiveDate"].ToString().Trim(); //有效日期
                objvUsersEN.Memo = objRow["Memo"].ToString().Trim(); //备注
                objvUsersEN.UpdDate = objRow["UpdDate"].ToString().Trim(); //修改日期
                objvUsersEN.UpdUser = objRow["UpdUser"].ToString().Trim(); //修改用户
                arrObjList.Add(objvUsersEN);
            }
            objDT = null;
            return arrObjList;
        }

        public static List<clsvUsersEN> GetvUsersObjListByRange(string strWhereCond, long lngMinNum, long lngMaxNum)
        {
            List<clsvUsersEN> arrObjList = new List<clsvUsersEN>();
            System.Data.DataTable objDT = null;
            objDT = GetDataTable_vUsersByRangeWs(strWhereCond, lngMinNum, lngMaxNum);
            if (objDT.Rows.Count == 0)
            {
                objDT = null;
                return arrObjList;
            }
            foreach (DataRow objRow in objDT.Rows)
            {
                clsvUsersEN objvUsersEN = new clsvUsersEN();
                objvUsersEN.UserId = objRow["UserId"].ToString().Trim(); //用户ID
                objvUsersEN.UserName = objRow["UserName"].ToString().Trim(); //用户名
                objvUsersEN.DepartmentId = objRow["DepartmentId"].ToString().Trim(); //部门Id
                objvUsersEN.DepartmentName = objRow["DepartmentName"].ToString().Trim(); //部门名
                objvUsersEN.UpDepartmentId = objRow["UpDepartmentId"].ToString().Trim(); //所属部门号
                objvUsersEN.DepartmentAbbrName = objRow["DepartmentAbbrName"].ToString().Trim(); //名称缩写
                objvUsersEN.UpDepartmentName = objRow["UpDepartmentName"].ToString().Trim(); //上级部门
                objvUsersEN.SubjectTypeName = objRow["SubjectTypeName"].ToString().Trim(); //学科类型
                objvUsersEN.DepartmentTypeId = objRow["DepartmentTypeId"].ToString().Trim(); //部门类型ID
                objvUsersEN.DepartmentTypeName = objRow["DepartmentTypeName"].ToString().Trim(); //部门类型名
                objvUsersEN.UserStateId = objRow["UserStateId"].ToString().Trim(); //用户状态Id
                objvUsersEN.UserStateName = objRow["UserStateName"].ToString().Trim(); //用户状态名
                objvUsersEN.EffectiveDate = objRow["EffectiveDate"].ToString().Trim(); //有效日期
                objvUsersEN.Memo = objRow["Memo"].ToString().Trim(); //备注
                objvUsersEN.UpdDate = objRow["UpdDate"].ToString().Trim(); //修改日期
                objvUsersEN.UpdUser = objRow["UpdUser"].ToString().Trim(); //修改用户
                arrObjList.Add(objvUsersEN);
            }
            objDT = null;
            return arrObjList;
        }

