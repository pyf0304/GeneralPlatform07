 ///生成绑定ListView的代码
 /// <summary>
 /// 函数功能:根据界面上查询控件中所设置内容查询表记录,
 ///			 并显示在ListView中。
 /// (AGC_CSV7.BusinessLogicEx.AutoGCPubFuncV6:GenBindListView)
 /// </summary>
public static int BindLv_vQxPotenceType(System.Windows.Forms.ListView lvvQxPotenceType, string strWhereCond)
{
//操作步骤:(共4步)
//	1、组合界面条件串；
//	2、根据条件串获取该表满足条件的DataTable；
//	3、设置ListView的列头信息
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
//		在本界面中是把状态显示在控件lblRecCount中。

System.Windows.Forms.ListViewItem lvivQxPotenceType; 
ArrayList arrvQxPotenceTypeObjList;
//	2、根据条件串获取该表满足条件的DataTable；
arrvQxPotenceTypeObjList = new clsvQxPotenceTypeBL.GetvQxPotenceTypeObjList(strWhereCond);
//	3、设置ListView的列头信息
lvvQxPotenceType.Items.Clear();//清除原来所有Item
lvvQxPotenceType.Columns.Clear();//清除原来所有列头信息
lvvQxPotenceType.Columns.Add("权限类型Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxPotenceType.Columns.Add("权限类型名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxPotenceType.Columns.Add("项目Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxPotenceType.Columns.Add("工程名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxPotenceType.Columns.Add("备注", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxPotenceType.Columns.Add("修改日期", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxPotenceType.Columns.Add("修改用户Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxPotenceType.View = System.Windows.Forms.View.Details;
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
foreach (clsvQxPotenceTypeEN objvQxPotenceTypeEN in arrvQxPotenceTypeObjList)
{
lvivQxPotenceType = new System.Windows.Forms.ListViewItem();
lvivQxPotenceType.Tag = objvQxPotenceTypeEN.PotenceTypeId;
lvivQxPotenceType.Text = objvQxPotenceTypeEN.PotenceTypeId.ToString();
lvivQxPotenceType.SubItems.Add(objvQxPotenceTypeEN.PotenceTypeName);
lvivQxPotenceType.SubItems.Add(objvQxPotenceTypeEN.QxPrjId);
lvivQxPotenceType.SubItems.Add(objvQxPotenceTypeEN.PrjName);
lvivQxPotenceType.SubItems.Add(objvQxPotenceTypeEN.Memo);
lvivQxPotenceType.SubItems.Add(objvQxPotenceTypeEN.UpdDate);
lvivQxPotenceType.SubItems.Add(objvQxPotenceTypeEN.UpdUserId);
lvvQxPotenceType.Items.Add(lvivQxPotenceType);
}
//	4、设置记录数的状态,
//		在本界面中是把状态显示在控件txtRecCount中。
return arrvQxPotenceTypeObjList.Count;
}

