    /// <summary>
    /// 隶属关系(SubjectRelation)
    /// </summary>
    public class clsSubjectRelationWS
    {

        private static SubjectRelationServiceSoapClient objSubjectRelationServiceSoapClient = null;
        /// <summary>
        /// 
        /// </summary>
        /// <returns></returns>
        public static SubjectRelationServiceSoapClient GetSubjectRelationServiceSoapClient()
        {
            if (objSubjectRelationServiceSoapClient == null)
            {
                BasicHttpBinding binding = new BasicHttpBinding();
                binding.Name = "SubjectRelationServiceSoap";
                binding.CloseTimeout = new System.TimeSpan(6000);

                //EndpointAddress address = new EndpointAddress("http://202.121.63.10/CalcEngineWS/SubjectRelationService.asmx");

                String strServiceUrl = String.Empty;
                if (clsSysPara.bolIsLocalHost == false)
                {
                    strServiceUrl = String.Format("http://{0}/{1}/SubjectRelationService.asmx", clsSysPara.CurrIPAddressAndPort, clsSysPara.CurrPrx);
                }
                else
                {
                    strServiceUrl = String.Format("http://{0}/SubjectRelationService.asmx", clsSysPara.strCurrIPAddressAndPort_Local);
                }


                //String strServiceUrl = String.Format("http://{0}/CalcEngineWS/SubjectRelationService.asmx", clsSysPara.strCurrIPAddress);
                EndpointAddress address = new EndpointAddress(strServiceUrl);

                return new SubjectRelationServiceSoapClient(binding, address);
            }
            else
            {
                return objSubjectRelationServiceSoapClient;
            }
        }
        /// <summary>
        /// 构造函数
        /// </summary>
        public clsSubjectRelationWS()
        {
        }


        /// <summary>
        /// 
        /// </summary>
        /// <param name="strWhereCond"></param>
        /// <returns></returns>
        public static DataTable GetDataTable_SubjectRelationWs(string strWhereCond)
        {
            SubjectRelationServiceSoapClient objSubjectRelationService = GetSubjectRelationServiceSoapClient();
            DataSet objDS = null;
            try
            {
                objDS = objSubjectRelationService.SubjectRelation_GetDataSet(strWhereCond);
                DataTable objDT = objDS.Tables[0];
                return objDT;
            }
            catch (Exception objException)
            {
                throw new Exception("获取表:SubjectRelation 数据出错！\r\n" + objException.Message);
            }
        }
        /// <summary>
        /// 
        /// </summary>
        /// <param name="strWhereCond"></param>
        /// <returns></returns>
        public static DataTable GetDataTable_SubjectRelationVWs(string strWhereCond)
        {
            SubjectRelationServiceSoapClient objSubjectRelationService = GetSubjectRelationServiceSoapClient();
            DataSet objDS = null;
