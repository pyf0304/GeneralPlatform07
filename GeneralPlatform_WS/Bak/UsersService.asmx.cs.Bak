        [WebMethod]
        public bool Users_AddNewRecordBySql2(clsUsersEN objUsersEN)
        {
            bool bolResult = clsUsersBL.AddNewRecordBySql2(objUsersEN);
            return bolResult;
        }

        [WebMethod]
        public string Users_AddNewRecordBySql2WithReturnKey(clsUsersEN objUsersEN)
