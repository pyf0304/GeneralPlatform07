 /// <summary>
 /// 根据关键字获取相关名称, 从缓存的对象列表中获取.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecNameByKey_Cache)
 /// </summary>
 /// <param name = "strIdentityID">所给的关键字</param>
 /// <returns>根据关键字获取的名称</returns>
public static string GetIdentityDescByIdentityID_Cache(string strIdentityID)
{
if (string.IsNullOrEmpty(strIdentityID) == true) return "";
string strWhereCond = string.Format("1 = 1 order by IdentityID");
if (arrQxUserIdentityObjLst_Cache == null)
{
arrQxUserIdentityObjLst_Cache = clsQxUserIdentityWS.GetQxUserIdentityObjList(strWhereCond);
}
int intStart = 0;
int intEnd = arrQxUserIdentityObjLst_Cache.Count - 1;
int intMid = 0;
clsQxUserIdentityEN objQxUserIdentityEN = null;
while (intEnd >= intStart)
{
intMid = (intStart + intEnd) / 2;
objQxUserIdentityEN = arrQxUserIdentityObjLst_Cache[intMid];
if (objQxUserIdentityEN.IdentityID == strIdentityID)
{
intFindFailCount = 0;
return objQxUserIdentityEN.IdentityDesc;
}
else if (objQxUserIdentityEN.IdentityID.CompareTo(strIdentityID) > 0)
{
intEnd = intMid - 1;
}
else
{
intStart = intMid + 1;
}
}
intFindFailCount++;
// 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
arrQxUserIdentityObjLst_Cache = null;
if (intFindFailCount == 1) return GetIdentityDescByIdentityID_Cache(strIdentityID);
string strErrMsgForGetObjById = string.Format("在QxUserIdentity对象缓存列表中,找不到记录[IdentityID = {0}][intFindFailCount = {1}](函数:GetIdentityDescByIdentityID_Cache)", strIdentityID, intFindFailCount);
if (objQxUserIdentityEN != null)
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objQxUserIdentityEN.IdentityID, intMid);
}
else
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
}
clsGeneralTab2.LogErrorS2("clsQxUserIdentityBL", "GetIdentityDescByIdentityID_Cache", strErrMsgForGetObjById, "", "");
throw new Exception(strErrMsgForGetObjById);
}

