public class clsDataBaseTypeWS
{
 /// <summary>
 /// 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:A_GenWebServiceTransCode)
 /// </summary>
public static List<clsDataBaseTypeEN> arrDataBaseTypeObjLst_Cache = null;
 /// <summary>
 /// 从缓存中查找失败的次数
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:A_GenWebServiceTransCode)
 /// </summary>
protected static int intFindFailCount = 0;
private static DataBaseTypeServiceSoapClient objDataBaseTypeServiceSoapClient = null;
 /// <summary>
 /// 
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:A_GenWebServiceTransCode)
 /// </summary>
 /// <returns></returns>
public static DataBaseTypeServiceSoapClient GetDataBaseTypeServiceSoapClient()
{
if (objDataBaseTypeServiceSoapClient == null)
{
BasicHttpBinding binding = new BasicHttpBinding();
binding.Name = "DataBaseTypeServiceSoap";
binding.CloseTimeout = new System.TimeSpan(6000);
binding.MaxReceivedMessageSize = 2147483647;
String strServiceUrl = String.Empty;
if (clsSysPara4WS.bolIsLocalHost == false)
{
strServiceUrl = String.Format("http://{0}/{1}/DataBaseTypeService.asmx", clsSysPara4WS.strCurrIPAddressAndPort, clsSysPara4WS.strCurrPrx);
}
else
{
strServiceUrl = String.Format("http://{0}/DataBaseTypeService.asmx", clsSysPara4WS.strCurrIPAddressAndPort_Local);
}
EndpointAddress address = new EndpointAddress(strServiceUrl);
return new DataBaseTypeServiceSoapClient(binding, address);
}
else
{
return objDataBaseTypeServiceSoapClient;
}
}

 public clsDataBaseTypeWS()
 {
 }

 /// <summary>
 /// 绑定基于Win的下拉框
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_ComboBoxBindFunction)
 /// </summary>
 /// <param name="objComboBox">需要绑定当前表的下拉框</param>
public static void BindCbo_DataBaseTypeId(System.Windows.Forms.ComboBox objComboBox)
{
//为数据源为表的下拉框设置内容
System.Data.DataTable objDT = GetDataTable_DataBaseTypeWs("1=1");
clsDataBaseTypeEN objDataBaseTypeEN;
//初始化一个对象列表
ArrayList DataBaseTypeList = new ArrayList();
//插入第0项。在第0项中插入“请选择...”,为了方便用户,与WEB方式类似。
objDataBaseTypeEN = new clsDataBaseTypeEN();
objDataBaseTypeEN.DataBaseTypeId = "0";
objDataBaseTypeEN.DataBaseTypeName = "请选择...";
DataBaseTypeList.Add(objDataBaseTypeEN);
//把DataTable中的所有项均加到对象列表中
foreach(DataRow objRow in objDT.Rows)
{
objDataBaseTypeEN = new clsDataBaseTypeEN();
objDataBaseTypeEN.DataBaseTypeId = objRow["DataBaseTypeId"].ToString();
objDataBaseTypeEN.DataBaseTypeName = objRow["DataBaseTypeName"].ToString();
DataBaseTypeList.Add(objDataBaseTypeEN);
}
//设置下拉框的数据源、以及设置值项、显示项
objComboBox.DataSource = DataBaseTypeList;
objComboBox.ValueMember="DataBaseTypeId";
objComboBox.DisplayMember="DataBaseTypeName";
objComboBox.SelectedIndex = 0;
}

 /// <summary>
 /// 绑定基于Web的下拉框
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_DdlBindFunction)
 /// </summary>
 /// <param name="objDDL">需要绑定当前表的下拉框</param>
public static void BindDdl_DataBaseTypeId(System.Web.UI.WebControls.DropDownList objDDL)
{
//为数据源于表的下拉框设置内容
System.Web.UI.WebControls.ListItem li=new System.Web.UI.WebControls.ListItem("请选择...","0");
System.Data.DataTable objDT = GetDataTable_DataBaseTypeWs("1=1");
objDDL.DataValueField="DataBaseTypeId";
objDDL.DataTextField="DataBaseTypeName";
objDDL.DataSource = objDT;
objDDL.DataBind();
objDDL.Items.Insert(0, li);
objDDL.SelectedIndex = 0;
}

 ///生成绑定ListView的代码
 /// <summary>
 /// 函数功能:根据界面上查询控件中所设置内容查询表记录,
 ///			 并显示在ListView中。
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_BindListView)
 /// </summary>
public static int BindLv_DataBaseType(System.Windows.Forms.ListView lvDataBaseType, string strWhereCond)
{
//操作步骤:(共4步)
//	1、组合界面条件串；
//	2、根据条件串获取该表满足条件的DataTable；
//	3、设置ListView的列头信息
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
//		在本界面中是把状态显示在控件lblRecCount中。

System.Windows.Forms.ListViewItem lviDataBaseType; 
List<clsDataBaseTypeEN> arrDataBaseTypeObjList;
//	2、根据条件串获取该表满足条件的DataTable；
arrDataBaseTypeObjList = GetDataBaseTypeObjList(strWhereCond);
//	3、设置ListView的列头信息
lvDataBaseType.Items.Clear();//清除原来所有Item
lvDataBaseType.Columns.Clear();//清除原来所有列头信息
lvDataBaseType.Columns.Add("数据库类型ID", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvDataBaseType.Columns.Add("数据库类型名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvDataBaseType.Columns.Add("备注", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvDataBaseType.View = System.Windows.Forms.View.Details;
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
foreach (clsDataBaseTypeEN objDataBaseTypeEN in arrDataBaseTypeObjList)
{
lviDataBaseType = new System.Windows.Forms.ListViewItem();
lviDataBaseType.Tag = objDataBaseTypeEN.DataBaseTypeId;
lviDataBaseType.Text = objDataBaseTypeEN.DataBaseTypeId.ToString();
lviDataBaseType.SubItems.Add(objDataBaseTypeEN.DataBaseTypeName);
lviDataBaseType.SubItems.Add(objDataBaseTypeEN.Memo);
lvDataBaseType.Items.Add(lviDataBaseType);
}
//	4、设置记录数的状态,
//		在本界面中是把状态显示在控件txtRecCount中。
return arrDataBaseTypeObjList.Count;
}

 /// <summary>
 /// 检查对象字段值是否合法,1)检查是否可空;2)检查字段值长度是否超长,如果出错就抛出错误.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4WS_CheckPropertyNew)
 /// </summary>
public void CheckPropertyNew(clsDataBaseTypeEN objDataBaseTypeEN)
{
if (!Object.Equals(null, objDataBaseTypeEN.DataBaseTypeId) && getStrLen(objDataBaseTypeEN.DataBaseTypeId) > 2)
{
 throw new Exception("字段[数据库类型ID]的长度不能超过2!");
}
if (!Object.Equals(null, objDataBaseTypeEN.DataBaseTypeName) && getStrLen(objDataBaseTypeEN.DataBaseTypeName) > 30)
{
 throw new Exception("字段[数据库类型名]的长度不能超过30!");
}
if (!Object.Equals(null, objDataBaseTypeEN.Memo) && getStrLen(objDataBaseTypeEN.Memo) > 1000)
{
 throw new Exception("字段[备注]的长度不能超过1000!");
}
 objDataBaseTypeEN.IsCheckProperty = true;
 }

 /// <summary>
 /// 根据条件获取数据表,用DataTable表示
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetDataTable4Tab)
 /// </summary>
 /// <param name = "strWhereCond">条件串</param>
 /// <returns>返回满足条件一定范围的DataTable</returns>
public static DataTable GetDataTable_DataBaseTypeWs(string strWhereCond)
{
DataBaseTypeServiceSoapClient objDataBaseTypeService = GetDataBaseTypeServiceSoapClient();
DataSet objDS = null;
try
{
objDS = objDataBaseTypeService.DataBaseType_GetDataSet(strWhereCond);
DataTable objDT = objDS.Tables[0];
return objDT;
}
catch (Exception objException)
{
 string strMsg = string.Format("执行WebService功能出错。文件地址:{0},函数名:{1}. 调用函数名:{2}.", 
      GetServiceUrl(), "DataBaseType_GetDataSet", "clsDataBaseTypeWS:GetDataTable_DataBaseTypeWs", objException.Message);
 strMsg += string.Format("出错信息:{0}",
      objException.Message);
 throw new Exception(strMsg);
}
}

