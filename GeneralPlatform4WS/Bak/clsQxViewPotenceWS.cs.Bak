 /// <summary>
 /// 根据关键字获取相关对象, 从缓存的对象列表中获取.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecObjByKey_Cache)
 /// </summary>
 /// <param name = "lngmId">所给的关键字</param>
 /// <returns>根据关键字获取的对象</returns>
public static clsQxViewPotenceEN GetQxViewPotenceObjBymId_Cache(long lngmId)
{
string strWhereCond = string.Format("1 = 1 order by mId");
if (arrQxViewPotenceObjLst_Cache == null)
{
arrQxViewPotenceObjLst_Cache = clsQxViewPotenceWS.GetQxViewPotenceObjList(strWhereCond);
}
int intStart = 0;
int intEnd = arrQxViewPotenceObjLst_Cache.Count - 1;
int intMid = 0;
clsQxViewPotenceEN objQxViewPotenceEN = null;
while (intEnd >= intStart)
{
intMid = (intStart + intEnd) / 2;
objQxViewPotenceEN = arrQxViewPotenceObjLst_Cache[intMid];
if (objQxViewPotenceEN.mId == lngmId)
{
intFindFailCount = 0;
return objQxViewPotenceEN;
}
else if (objQxViewPotenceEN.mId.CompareTo(lngmId) > 0)
{
intEnd = intMid - 1;
}
else
{
intStart = intMid + 1;
}
}
intFindFailCount++;
// 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
arrQxViewPotenceObjLst_Cache = null;
if (intFindFailCount == 1) return GetQxViewPotenceObjBymId_Cache(lngmId);
string strErrMsgForGetObjById = string.Format("在QxViewPotence对象缓存列表中,找不到记录[mId = {0}][intFindFailCount = {1}](函数:GetQxViewPotenceObjBymId_Cache)", lngmId, intFindFailCount);
if (objQxViewPotenceEN != null)
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objQxViewPotenceEN.mId, intMid);
}
else
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
}
clsGeneralTab2.LogErrorS2("clsQxViewPotenceBL", "GetQxViewPotenceObjBymId_Cache", strErrMsgForGetObjById, "", "");
throw new Exception(strErrMsgForGetObjById);
}

public static List<clsQxViewPotenceEN> GetQxViewPotenceObjList(string strWhereCond)
{
 List<clsQxViewPotenceEN> arrObjList = new List<clsQxViewPotenceEN>(); 
System.Data.DataTable objDT = null; 
 objDT = GetDataTable_QxViewPotenceWs(strWhereCond);
if (objDT.Rows.Count == 0)
{
objDT = null;
return arrObjList;
}
foreach(DataRow objRow in objDT.Rows)
{
	clsQxViewPotenceEN objQxViewPotenceEN = new clsQxViewPotenceEN();
objQxViewPotenceEN.mId = Int32.Parse(objRow["mId"].ToString().Trim()); //流水号
objQxViewPotenceEN.ViewId = objRow["ViewId"].ToString().Trim(); //界面编号
objQxViewPotenceEN.QxPrjId = objRow["QxPrjId"].ToString().Trim(); //项目Id
objQxViewPotenceEN.PotenceId = objRow["PotenceId"].ToString().Trim(); //权限ID
objQxViewPotenceEN.Level = Int32.Parse(objRow["Level"].ToString().Trim()); //等级
objQxViewPotenceEN.Memo = objRow["Memo"].ToString().Trim(); //备注
	arrObjList.Add(objQxViewPotenceEN);
	}
objDT = null;
return arrObjList;
}

