public static List<clsSubjectRelationEN> arrSubjectRelationObjLst_Cache = null;
 /// <summary>
 /// 从缓存中查找失败的次数
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:A_GenWebServiceTransCode)
 /// </summary>
protected static int intFindFailCount = 0;
private static SubjectRelationServiceSoapClient objSubjectRelationServiceSoapClient = null;
 /// <summary>
 /// 
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:A_GenWebServiceTransCode)
 /// </summary>
 /// <returns></returns>
public static SubjectRelationServiceSoapClient GetSubjectRelationServiceSoapClient()
{
if (objSubjectRelationServiceSoapClient == null)
{
BasicHttpBinding binding = new BasicHttpBinding();
binding.Name = "SubjectRelationServiceSoap";
binding.CloseTimeout = new System.TimeSpan(6000);
binding.MaxReceivedMessageSize = 2147483647;
String strServiceUrl = String.Empty;
if (clsSysPara4WS.bolIsLocalHost == false)
{
strServiceUrl = String.Format("http://{0}/{1}/SubjectRelationService.asmx", clsSysPara4WS.strCurrIPAddressAndPort, clsSysPara4WS.strCurrPrx);
}
else
{
strServiceUrl = String.Format("http://{0}/SubjectRelationService.asmx", clsSysPara4WS.strCurrIPAddressAndPort_Local);
}
EndpointAddress address = new EndpointAddress(strServiceUrl);
return new SubjectRelationServiceSoapClient(binding, address);
}
else
{
return objSubjectRelationServiceSoapClient;
}
}

 public clsSubjectRelationWS()
 {
 }



 ///生成绑定ListView的代码
 /// <summary>
 /// 函数功能:根据界面上查询控件中所设置内容查询表记录,
 ///			 并显示在ListView中。
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_BindListView)
 /// </summary>
public static int BindLv_SubjectRelation(System.Windows.Forms.ListView lvSubjectRelation, string strWhereCond)
{
//操作步骤:(共4步)
//	1、组合界面条件串；
//	2、根据条件串获取该表满足条件的DataTable；
//	3、设置ListView的列头信息
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
//		在本界面中是把状态显示在控件lblRecCount中。

System.Windows.Forms.ListViewItem lviSubjectRelation; 
List<clsSubjectRelationEN> arrSubjectRelationObjList;
//	2、根据条件串获取该表满足条件的DataTable；
arrSubjectRelationObjList = GetSubjectRelationObjList(strWhereCond);
//	3、设置ListView的列头信息
lvSubjectRelation.Items.Clear();//清除原来所有Item
lvSubjectRelation.Columns.Clear();//清除原来所有列头信息
lvSubjectRelation.Columns.Add("流水号", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvSubjectRelation.Columns.Add("用户ID", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvSubjectRelation.Columns.Add("领导Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvSubjectRelation.Columns.Add("是否直接领导", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvSubjectRelation.Columns.Add("备注", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvSubjectRelation.View = System.Windows.Forms.View.Details;
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
foreach (clsSubjectRelationEN objSubjectRelationEN in arrSubjectRelationObjList)
{
lviSubjectRelation = new System.Windows.Forms.ListViewItem();
lviSubjectRelation.Tag = objSubjectRelationEN.mId;
lviSubjectRelation.Text = objSubjectRelationEN.mId.ToString();
lviSubjectRelation.SubItems.Add(objSubjectRelationEN.UserId);
lviSubjectRelation.SubItems.Add(objSubjectRelationEN.LeaderId);
lviSubjectRelation.SubItems.Add(objSubjectRelationEN.IsDirectLeader.ToString());
lviSubjectRelation.SubItems.Add(objSubjectRelationEN.Memo);
lvSubjectRelation.Items.Add(lviSubjectRelation);
}
//	4、设置记录数的状态,
//		在本界面中是把状态显示在控件txtRecCount中。
return arrSubjectRelationObjList.Count;
}

 /// <summary>
 /// 检查对象字段值是否合法,1)检查是否可空;2)检查字段值长度是否超长,如果出错就抛出错误.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4WS_CheckPropertyNew)
 /// </summary>
public void CheckPropertyNew(clsSubjectRelationEN objSubjectRelationEN)
{
if (!Object.Equals(null, objSubjectRelationEN.UserId) && getStrLen(objSubjectRelationEN.UserId) > 18)
{
 throw new Exception("字段[用户ID]的长度不能超过18!");
}
if (!Object.Equals(null, objSubjectRelationEN.LeaderId) && getStrLen(objSubjectRelationEN.LeaderId) > 18)
{
 throw new Exception("字段[领导Id]的长度不能超过18!");
}
if (!Object.Equals(null, objSubjectRelationEN.Memo) && getStrLen(objSubjectRelationEN.Memo) > 1000)
{
 throw new Exception("字段[备注]的长度不能超过1000!");
}
 objSubjectRelationEN.IsCheckProperty = true;
 }

