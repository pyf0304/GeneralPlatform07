 /// <summary>
 /// 根据关键字获取相关名称, 从缓存的对象列表中获取.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecNameByKey_Cache)
 /// </summary>
 /// <param name = "strDepartmentTypeId">所给的关键字</param>
 /// <returns>根据关键字获取的名称</returns>
public static string GetDepartmentTypeNameByDepartmentTypeId_Cache(string strDepartmentTypeId)
{
if (string.IsNullOrEmpty(strDepartmentTypeId) == true) return "";
string strWhereCond = string.Format("1 = 1 order by DepartmentTypeId");
if (arrQxDepartmentTypeObjLst_Cache == null)
{
arrQxDepartmentTypeObjLst_Cache = clsQxDepartmentTypeWS.GetQxDepartmentTypeObjList(strWhereCond);
}
int intStart = 0;
int intEnd = arrQxDepartmentTypeObjLst_Cache.Count - 1;
int intMid = 0;
clsQxDepartmentTypeEN objQxDepartmentTypeEN = null;
while (intEnd >= intStart)
{
intMid = (intStart + intEnd) / 2;
objQxDepartmentTypeEN = arrQxDepartmentTypeObjLst_Cache[intMid];
if (objQxDepartmentTypeEN.DepartmentTypeId == strDepartmentTypeId)
{
intFindFailCount = 0;
return objQxDepartmentTypeEN.DepartmentTypeName;
}
else if (objQxDepartmentTypeEN.DepartmentTypeId.CompareTo(strDepartmentTypeId) > 0)
{
intEnd = intMid - 1;
}
else
{
intStart = intMid + 1;
}
}
intFindFailCount++;
// 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
arrQxDepartmentTypeObjLst_Cache = null;
if (intFindFailCount == 1) return GetDepartmentTypeNameByDepartmentTypeId_Cache(strDepartmentTypeId);
string strErrMsgForGetObjById = string.Format("在QxDepartmentType对象缓存列表中,找不到记录[DepartmentTypeId = {0}][intFindFailCount = {1}](函数:GetDepartmentTypeNameByDepartmentTypeId_Cache)", strDepartmentTypeId, intFindFailCount);
if (objQxDepartmentTypeEN != null)
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objQxDepartmentTypeEN.DepartmentTypeId, intMid);
}
else
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
}
clsGeneralTab2.LogErrorS2("clsQxDepartmentTypeBL", "GetDepartmentTypeNameByDepartmentTypeId_Cache", strErrMsgForGetObjById, "", "");
throw new Exception(strErrMsgForGetObjById);
}

