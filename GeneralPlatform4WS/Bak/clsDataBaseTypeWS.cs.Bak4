public static List<clsDataBaseTypeEN> GetDataBaseTypeObjList(string strWhereCond)
{
 List<clsDataBaseTypeEN> arrObjList = new List<clsDataBaseTypeEN>(); 
System.Data.DataTable objDT = null; 
 objDT = GetDataTable_DataBaseTypeWs(strWhereCond);
if (objDT.Rows.Count == 0)
{
objDT = null;
return arrObjList;
}
foreach(DataRow objRow in objDT.Rows)
{
	clsDataBaseTypeEN objDataBaseTypeEN = new clsDataBaseTypeEN();
objDataBaseTypeEN.DataBaseTypeId = objRow["DataBaseTypeId"].ToString().Trim(); //数据库类型ID
objDataBaseTypeEN.DataBaseTypeName = objRow["DataBaseTypeName"].ToString().Trim(); //数据库类型名
objDataBaseTypeEN.Memo = objRow["Memo"].ToString().Trim(); //备注
	arrObjList.Add(objDataBaseTypeEN);
	}
objDT = null;
return arrObjList;
}

