public static List<clsQxUserIdentityEN> GetQxUserIdentityObjList(string strWhereCond)
{
 List<clsQxUserIdentityEN> arrObjList = new List<clsQxUserIdentityEN>(); 
System.Data.DataTable objDT = null; 
 objDT = GetDataTable_QxUserIdentityWs(strWhereCond);
if (objDT.Rows.Count == 0)
{
objDT = null;
return arrObjList;
}
foreach(DataRow objRow in objDT.Rows)
{
	clsQxUserIdentityEN objQxUserIdentityEN = new clsQxUserIdentityEN();
objQxUserIdentityEN.IdentityID = objRow["IdentityID"].ToString().Trim(); //身份编号
objQxUserIdentityEN.IdentityDesc = objRow["IdentityDesc"].ToString().Trim(); //身份描述
objQxUserIdentityEN.Memo = objRow["Memo"].ToString().Trim(); //备注
	arrObjList.Add(objQxUserIdentityEN);
	}
objDT = null;
return arrObjList;
}

