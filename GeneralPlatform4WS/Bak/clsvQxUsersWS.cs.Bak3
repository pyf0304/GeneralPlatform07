public static List<clsvQxUsersEN> arrvQxUsersObjLst_Cache = null;
 /// <summary>
 /// 从缓存中查找失败的次数
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:A_GenWebServiceTransCode)
 /// </summary>
protected static int intFindFailCount = 0;
private static vQxUsersServiceSoapClient objvQxUsersServiceSoapClient = null;
 /// <summary>
 /// 
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:A_GenWebServiceTransCode)
 /// </summary>
 /// <returns></returns>
public static vQxUsersServiceSoapClient GetvQxUsersServiceSoapClient()
{
if (objvQxUsersServiceSoapClient == null)
{
BasicHttpBinding binding = new BasicHttpBinding();
binding.Name = "vQxUsersServiceSoap";
binding.CloseTimeout = new System.TimeSpan(6000);
binding.MaxReceivedMessageSize = 2147483647;
String strServiceUrl = String.Empty;
if (clsSysPara4WS.bolIsLocalHost == false)
{
strServiceUrl = String.Format("http://{0}/{1}/vQxUsersService.asmx", clsSysPara4WS.strCurrIPAddressAndPort, clsSysPara4WS.strCurrPrx);
}
else
{
strServiceUrl = String.Format("http://{0}/vQxUsersService.asmx", clsSysPara4WS.strCurrIPAddressAndPort_Local);
}
EndpointAddress address = new EndpointAddress(strServiceUrl);
return new vQxUsersServiceSoapClient(binding, address);
}
else
{
return objvQxUsersServiceSoapClient;
}
}

 public clsvQxUsersWS()
 {
 }



 ///生成绑定ListView的代码
 /// <summary>
 /// 函数功能:根据界面上查询控件中所设置内容查询表记录,
 ///			 并显示在ListView中。
 /// (AGC_CSV7.BusinessLogicEx.AutoGCPubFuncV6:GenBindListView)
 /// </summary>
public static int BindLv_vQxUsers(System.Windows.Forms.ListView lvvQxUsers, string strWhereCond)
{
//操作步骤:(共4步)
//	1、组合界面条件串；
//	2、根据条件串获取该表满足条件的DataTable；
//	3、设置ListView的列头信息
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
//		在本界面中是把状态显示在控件lblRecCount中。

System.Windows.Forms.ListViewItem lvivQxUsers; 
ArrayList arrvQxUsersObjList;
//	2、根据条件串获取该表满足条件的DataTable；
arrvQxUsersObjList = new clsvQxUsersBL.GetvQxUsersObjList(strWhereCond);
//	3、设置ListView的列头信息
lvvQxUsers.Items.Clear();//清除原来所有Item
lvvQxUsers.Columns.Clear();//清除原来所有列头信息
lvvQxUsers.Columns.Add("用户ID", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("用户名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("部门Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("部门名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("名称缩写", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("部门类型ID", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("部门类型名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("所属部门号", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("上级部门", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("用户状态Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("用户状态名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("有效日期", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("口令", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("学院流水号", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("有效开始日期", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("有效结束日期", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("学工号", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("身份编号", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("身份描述", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("修改日期", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("修改用户", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.Columns.Add("备注", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvQxUsers.View = System.Windows.Forms.View.Details;
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
foreach (clsvQxUsersEN objvQxUsersEN in arrvQxUsersObjList)
{
lvivQxUsers = new System.Windows.Forms.ListViewItem();
lvivQxUsers.Tag = objvQxUsersEN.UserId;
lvivQxUsers.Text = objvQxUsersEN.UserId.ToString();
lvivQxUsers.SubItems.Add(objvQxUsersEN.UserName);
lvivQxUsers.SubItems.Add(objvQxUsersEN.DepartmentId);
lvivQxUsers.SubItems.Add(objvQxUsersEN.DepartmentName);
lvivQxUsers.SubItems.Add(objvQxUsersEN.DepartmentAbbrName);
lvivQxUsers.SubItems.Add(objvQxUsersEN.DepartmentTypeId);
lvivQxUsers.SubItems.Add(objvQxUsersEN.DepartmentTypeName);
lvivQxUsers.SubItems.Add(objvQxUsersEN.UpDepartmentId);
lvivQxUsers.SubItems.Add(objvQxUsersEN.UpDepartmentName);
lvivQxUsers.SubItems.Add(objvQxUsersEN.UserStateId);
lvivQxUsers.SubItems.Add(objvQxUsersEN.UserStateName);
lvivQxUsers.SubItems.Add(objvQxUsersEN.EffectiveDate);
lvivQxUsers.SubItems.Add(objvQxUsersEN.Password);
lvivQxUsers.SubItems.Add(objvQxUsersEN.id_College);
lvivQxUsers.SubItems.Add(objvQxUsersEN.EffitiveBeginDate);
lvivQxUsers.SubItems.Add(objvQxUsersEN.EffitiveEndDate);
lvivQxUsers.SubItems.Add(objvQxUsersEN.StuTeacherId);
lvivQxUsers.SubItems.Add(objvQxUsersEN.IdentityID);
lvivQxUsers.SubItems.Add(objvQxUsersEN.IdentityDesc);
lvivQxUsers.SubItems.Add(objvQxUsersEN.UpdDate);
lvivQxUsers.SubItems.Add(objvQxUsersEN.UpdUser);
lvivQxUsers.SubItems.Add(objvQxUsersEN.Memo);
lvvQxUsers.Items.Add(lvivQxUsers);
}
//	4、设置记录数的状态,
//		在本界面中是把状态显示在控件txtRecCount中。
return arrvQxUsersObjList.Count;
}

 /// <summary>
 /// 根据条件获取数据表,用DataTable表示
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetDataTable4Tab)
 /// </summary>
 /// <param name = "strWhereCond">条件串</param>
 /// <returns>返回满足条件一定范围的DataTable</returns>
public static DataTable GetDataTable_vQxUsersWs(string strWhereCond)
{
vQxUsersServiceSoapClient objvQxUsersService = GetvQxUsersServiceSoapClient();
DataSet objDS = null;
try
{
objDS = objvQxUsersService.vQxUsers_GetDataSet(strWhereCond);
DataTable objDT = objDS.Tables[0];
return objDT;
}
catch (Exception objException)
{
 string strMsg = string.Format("执行WebService功能出错。文件地址:{0},函数名:{1}. 调用函数名:{2}.", 
      GetServiceUrl(), "vQxUsers_GetDataSet", "clsvQxUsersWS:GetDataTable_vQxUsersWs", objException.Message);
 strMsg += string.Format("出错信息:{0}",
      objException.Message);
 throw new Exception(strMsg);
}
}

