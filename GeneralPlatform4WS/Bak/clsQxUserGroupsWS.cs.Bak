 /// <summary>
 /// 根据关键字获取相关对象, 从缓存的对象列表中获取.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecObjByKey_Cache)
 /// </summary>
 /// <param name = "strGroupId">所给的关键字</param>
 /// <returns>根据关键字获取的对象</returns>
public static clsQxUserGroupsEN GetQxUserGroupsObjByGroupId_Cache(string strGroupId)
{
if (string.IsNullOrEmpty(strGroupId) == true) return null;
string strWhereCond = string.Format("1 = 1 order by GroupId");
if (arrQxUserGroupsObjLst_Cache == null)
{
arrQxUserGroupsObjLst_Cache = clsQxUserGroupsWS.GetQxUserGroupsObjList(strWhereCond);
}
int intStart = 0;
int intEnd = arrQxUserGroupsObjLst_Cache.Count - 1;
int intMid = 0;
clsQxUserGroupsEN objQxUserGroupsEN = null;
while (intEnd >= intStart)
{
intMid = (intStart + intEnd) / 2;
objQxUserGroupsEN = arrQxUserGroupsObjLst_Cache[intMid];
if (objQxUserGroupsEN.GroupId == strGroupId)
{
intFindFailCount = 0;
return objQxUserGroupsEN;
}
else if (objQxUserGroupsEN.GroupId.CompareTo(strGroupId) > 0)
{
intEnd = intMid - 1;
}
else
{
intStart = intMid + 1;
}
}
intFindFailCount++;
// 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
arrQxUserGroupsObjLst_Cache = null;
if (intFindFailCount == 1) return GetQxUserGroupsObjByGroupId_Cache(strGroupId);
string strErrMsgForGetObjById = string.Format("在QxUserGroups对象缓存列表中,找不到记录[GroupId = {0}][intFindFailCount = {1}](函数:GetQxUserGroupsObjByGroupId_Cache)", strGroupId, intFindFailCount);
if (objQxUserGroupsEN != null)
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objQxUserGroupsEN.GroupId, intMid);
}
else
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
}
clsGeneralTab2.LogErrorS2("clsQxUserGroupsBL", "GetQxUserGroupsObjByGroupId_Cache", strErrMsgForGetObjById, "", "");
throw new Exception(strErrMsgForGetObjById);
}

public static List<clsQxUserGroupsEN> GetQxUserGroupsObjList(string strWhereCond)
{
 List<clsQxUserGroupsEN> arrObjList = new List<clsQxUserGroupsEN>(); 
System.Data.DataTable objDT = null; 
 objDT = GetDataTable_QxUserGroupsWs(strWhereCond);
if (objDT.Rows.Count == 0)
{
objDT = null;
return arrObjList;
}
foreach(DataRow objRow in objDT.Rows)
{
	clsQxUserGroupsEN objQxUserGroupsEN = new clsQxUserGroupsEN();
objQxUserGroupsEN.GroupId = objRow["GroupId"].ToString().Trim(); //组Id
objQxUserGroupsEN.GroupName = objRow["GroupName"].ToString().Trim(); //组名
objQxUserGroupsEN.QxPrjId = objRow["QxPrjId"].ToString().Trim(); //项目Id
objQxUserGroupsEN.Memo = objRow["Memo"].ToString().Trim(); //备注
	arrObjList.Add(objQxUserGroupsEN);
	}
objDT = null;
return arrObjList;
}

