 /// <summary>
 /// 绑定基于Web的下拉框
 /// (AGC_CSV7.BusinessLogicEx.AutoGCPubFuncV6:GenDdlBindFunction)
 /// </summary>
 /// <param name = "objDDL">需要绑定当前表的下拉框</param>
public static void BindDdl_DepartmentTypeId(System.Web.UI.WebControls.DropDownList objDDL)
{
//为数据源于表的下拉框设置内容
System.Web.UI.WebControls.ListItem li = new System.Web.UI.WebControls.ListItem("请选择...","0");
System.Data.DataTable objDT = GetDepartmentTypeId();
objDDL.DataValueField = clsQxDepartmentTypeEN.con_DepartmentTypeId;
objDDL.DataTextField = clsQxDepartmentTypeEN.con_DepartmentTypeName;
objDDL.DataSource = objDT;
objDDL.DataBind();
objDDL.Items.Insert(0, li);
objDDL.SelectedIndex = 0;
}

 ///生成绑定ListView的代码
 /// <summary>
 /// 函数功能:根据界面上查询控件中所设置内容查询表记录,
 ///			 并显示在ListView中。
 /// (AGC_CSV7.BusinessLogicEx.AutoGCPubFuncV6:GenBindListView)
 /// </summary>
public static int BindLv_QxDepartmentType(System.Windows.Forms.ListView lvQxDepartmentType, string strWhereCond)
{
//操作步骤:(共4步)
//	1、组合界面条件串；
//	2、根据条件串获取该表满足条件的DataTable；
//	3、设置ListView的列头信息
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
//		在本界面中是把状态显示在控件lblRecCount中。

System.Windows.Forms.ListViewItem lviQxDepartmentType; 
ArrayList arrQxDepartmentTypeObjList;
//	2、根据条件串获取该表满足条件的DataTable；
arrQxDepartmentTypeObjList = new clsQxDepartmentTypeBL.GetQxDepartmentTypeObjList(strWhereCond);
//	3、设置ListView的列头信息
lvQxDepartmentType.Items.Clear();//清除原来所有Item
lvQxDepartmentType.Columns.Clear();//清除原来所有列头信息
lvQxDepartmentType.Columns.Add("部门类型ID", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxDepartmentType.Columns.Add("部门类型名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxDepartmentType.Columns.Add("备注", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxDepartmentType.View = System.Windows.Forms.View.Details;
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
foreach (clsQxDepartmentTypeEN objQxDepartmentTypeEN in arrQxDepartmentTypeObjList)
{
lviQxDepartmentType = new System.Windows.Forms.ListViewItem();
lviQxDepartmentType.Tag = objQxDepartmentTypeEN.DepartmentTypeId;
lviQxDepartmentType.Text = objQxDepartmentTypeEN.DepartmentTypeId.ToString();
lviQxDepartmentType.SubItems.Add(objQxDepartmentTypeEN.DepartmentTypeName);
lviQxDepartmentType.SubItems.Add(objQxDepartmentTypeEN.Memo);
lvQxDepartmentType.Items.Add(lviQxDepartmentType);
}
//	4、设置记录数的状态,
//		在本界面中是把状态显示在控件txtRecCount中。
return arrQxDepartmentTypeObjList.Count;
}

 /// <summary>
 /// 检查对象字段值是否合法,1)检查是否可空;2)检查字段值长度是否超长,如果出错就抛出错误.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4WS_CheckPropertyNew)
 /// </summary>
public void CheckPropertyNew(clsQxDepartmentTypeEN objQxDepartmentTypeEN)
{
if (!Object.Equals(null, objQxDepartmentTypeEN.DepartmentTypeId) && getStrLen(objQxDepartmentTypeEN.DepartmentTypeId) > 2)
{
 throw new Exception("字段[部门类型ID]的长度不能超过2!");
}
if (!Object.Equals(null, objQxDepartmentTypeEN.DepartmentTypeName) && getStrLen(objQxDepartmentTypeEN.DepartmentTypeName) > 50)
{
 throw new Exception("字段[部门类型名]的长度不能超过50!");
}
if (!Object.Equals(null, objQxDepartmentTypeEN.Memo) && getStrLen(objQxDepartmentTypeEN.Memo) > 1000)
{
 throw new Exception("字段[备注]的长度不能超过1000!");
}
 objQxDepartmentTypeEN.IsCheckProperty = true;
 }

