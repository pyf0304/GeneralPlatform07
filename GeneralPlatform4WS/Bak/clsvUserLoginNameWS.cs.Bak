 /// <summary>
 /// 根据关键字获取相关对象, 从缓存的对象列表中获取.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecObjByKey_Cache)
 /// </summary>
 /// <param name = "strUserLoginName">所给的关键字</param>
 /// <returns>根据关键字获取的对象</returns>
public static clsvUserLoginNameEN GetvUserLoginNameObjByUserLoginName_Cache(string strUserLoginName)
{
if (string.IsNullOrEmpty(strUserLoginName) == true) return null;
string strWhereCond = string.Format("1 = 1 order by UserLoginName");
if (arrvUserLoginNameObjLst_Cache == null)
{
arrvUserLoginNameObjLst_Cache = clsvUserLoginNameWS.GetvUserLoginNameObjList(strWhereCond);
}
int intStart = 0;
int intEnd = arrvUserLoginNameObjLst_Cache.Count - 1;
int intMid = 0;
clsvUserLoginNameEN objvUserLoginNameEN = null;
while (intEnd >= intStart)
{
intMid = (intStart + intEnd) / 2;
objvUserLoginNameEN = arrvUserLoginNameObjLst_Cache[intMid];
if (objvUserLoginNameEN.UserLoginName == strUserLoginName)
{
intFindFailCount = 0;
return objvUserLoginNameEN;
}
else if (objvUserLoginNameEN.UserLoginName.CompareTo(strUserLoginName) > 0)
{
intEnd = intMid - 1;
}
else
{
intStart = intMid + 1;
}
}
intFindFailCount++;
// 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
arrvUserLoginNameObjLst_Cache = null;
if (intFindFailCount == 1) return GetvUserLoginNameObjByUserLoginName_Cache(strUserLoginName);
string strErrMsgForGetObjById = string.Format("在vUserLoginName对象缓存列表中,找不到记录[UserLoginName = {0}][intFindFailCount = {1}](函数:GetvUserLoginNameObjByUserLoginName_Cache)", strUserLoginName, intFindFailCount);
if (objvUserLoginNameEN != null)
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objvUserLoginNameEN.UserLoginName, intMid);
}
else
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
}
clsGeneralTab2.LogErrorS2("clsvUserLoginNameBL", "GetvUserLoginNameObjByUserLoginName_Cache", strErrMsgForGetObjById, "", "");
throw new Exception(strErrMsgForGetObjById);
}

public static List<clsvUserLoginNameEN> GetvUserLoginNameObjList(string strWhereCond)
{
 List<clsvUserLoginNameEN> arrObjList = new List<clsvUserLoginNameEN>(); 
System.Data.DataTable objDT = null; 
 objDT = GetDataTable_vUserLoginNameWs(strWhereCond);
if (objDT.Rows.Count == 0)
{
objDT = null;
return arrObjList;
}
foreach(DataRow objRow in objDT.Rows)
{
	clsvUserLoginNameEN objvUserLoginNameEN = new clsvUserLoginNameEN();
objvUserLoginNameEN.UserLoginName = objRow["UserLoginName"].ToString().Trim(); //用户登录名
objvUserLoginNameEN.UserId = objRow["UserId"].ToString().Trim(); //用户ID
objvUserLoginNameEN.UserName = objRow["UserName"].ToString().Trim(); //用户名
objvUserLoginNameEN.DepartmentId = objRow["DepartmentId"].ToString().Trim(); //部门Id
objvUserLoginNameEN.DepartmentName = objRow["DepartmentName"].ToString().Trim(); //部门名
objvUserLoginNameEN.DepartmentAbbrName = objRow["DepartmentAbbrName"].ToString().Trim(); //名称缩写
objvUserLoginNameEN.UserStateId = objRow["UserStateId"].ToString().Trim(); //用户状态Id
objvUserLoginNameEN.UserStateName = objRow["UserStateName"].ToString().Trim(); //用户状态名
objvUserLoginNameEN.Password = objRow["Password"].ToString().Trim(); //口令
objvUserLoginNameEN.EffitiveBeginDate = objRow["EffitiveBeginDate"].ToString().Trim(); //有效开始日期
objvUserLoginNameEN.EffitiveEndDate = objRow["EffitiveEndDate"].ToString().Trim(); //有效结束日期
objvUserLoginNameEN.StuTeacherId = objRow["StuTeacherId"].ToString().Trim(); //学工号
objvUserLoginNameEN.IdentityID = objRow["IdentityID"].ToString().Trim(); //身份编号
objvUserLoginNameEN.IdentityDesc = objRow["IdentityDesc"].ToString().Trim(); //身份描述
objvUserLoginNameEN.Memo = objRow["Memo"].ToString().Trim(); //备注
	arrObjList.Add(objvUserLoginNameEN);
	}
objDT = null;
return arrObjList;
}

