 ///生成绑定ListView的代码
 /// <summary>
 /// 函数功能:根据界面上查询控件中所设置内容查询表记录,
 ///			 并显示在ListView中。
 /// (AGC_CSV7.BusinessLogicEx.AutoGCPubFuncV6:GenBindListView)
 /// </summary>
public static int BindLv_vUserLoginName(System.Windows.Forms.ListView lvvUserLoginName, string strWhereCond)
{
//操作步骤:(共4步)
//	1、组合界面条件串；
//	2、根据条件串获取该表满足条件的DataTable；
//	3、设置ListView的列头信息
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
//		在本界面中是把状态显示在控件lblRecCount中。

System.Windows.Forms.ListViewItem lvivUserLoginName; 
ArrayList arrvUserLoginNameObjList;
//	2、根据条件串获取该表满足条件的DataTable；
arrvUserLoginNameObjList = new clsvUserLoginNameBL.GetvUserLoginNameObjList(strWhereCond);
//	3、设置ListView的列头信息
lvvUserLoginName.Items.Clear();//清除原来所有Item
lvvUserLoginName.Columns.Clear();//清除原来所有列头信息
lvvUserLoginName.Columns.Add("用户登录名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("用户ID", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("用户名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("部门Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("部门名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("名称缩写", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("用户状态Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("用户状态名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("口令", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("有效开始日期", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("有效结束日期", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("学工号", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("身份编号", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("身份描述", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.Columns.Add("备注", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvvUserLoginName.View = System.Windows.Forms.View.Details;
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
foreach (clsvUserLoginNameEN objvUserLoginNameEN in arrvUserLoginNameObjList)
{
lvivUserLoginName = new System.Windows.Forms.ListViewItem();
lvivUserLoginName.Tag = objvUserLoginNameEN.UserLoginName;
lvivUserLoginName.Text = objvUserLoginNameEN.UserLoginName.ToString();
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.UserId);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.UserName);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.DepartmentId);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.DepartmentName);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.DepartmentAbbrName);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.UserStateId);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.UserStateName);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.Password);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.EffitiveBeginDate);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.EffitiveEndDate);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.StuTeacherId);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.IdentityID);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.IdentityDesc);
lvivUserLoginName.SubItems.Add(objvUserLoginNameEN.Memo);
lvvUserLoginName.Items.Add(lvivUserLoginName);
}
//	4、设置记录数的状态,
//		在本界面中是把状态显示在控件txtRecCount中。
return arrvUserLoginNameObjList.Count;
}

