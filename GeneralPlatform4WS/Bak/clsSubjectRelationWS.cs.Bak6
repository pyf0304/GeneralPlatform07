 /// <summary>
 /// 根据关键字获取相关对象, 从缓存的对象列表中获取.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecObjByKey_Cache)
 /// </summary>
 /// <param name = "lngmId">所给的关键字</param>
 /// <returns>根据关键字获取的对象</returns>
public static clsSubjectRelationEN GetSubjectRelationObjBymId_Cache(long lngmId)
{
string strWhereCond = string.Format("1 = 1 order by mId");
if (arrSubjectRelationObjLst_Cache == null)
{
arrSubjectRelationObjLst_Cache = clsSubjectRelationWS.GetSubjectRelationObjList(strWhereCond);
}
int intStart = 0;
int intEnd = arrSubjectRelationObjLst_Cache.Count - 1;
int intMid = 0;
clsSubjectRelationEN objSubjectRelationEN = null;
while (intEnd >= intStart)
{
intMid = (intStart + intEnd) / 2;
objSubjectRelationEN = arrSubjectRelationObjLst_Cache[intMid];
if (objSubjectRelationEN.mId == lngmId)
{
intFindFailCount = 0;
return objSubjectRelationEN;
}
else if (objSubjectRelationEN.mId.CompareTo(lngmId) > 0)
{
intEnd = intMid - 1;
}
else
{
intStart = intMid + 1;
}
}
intFindFailCount++;
// 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
arrSubjectRelationObjLst_Cache = null;
if (intFindFailCount == 1) return GetSubjectRelationObjBymId_Cache(lngmId);
string strErrMsgForGetObjById = string.Format("在SubjectRelation对象缓存列表中,找不到记录[mId = {0}][intFindFailCount = {1}](函数:GetSubjectRelationObjBymId_Cache)", lngmId, intFindFailCount);
if (objSubjectRelationEN != null)
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objSubjectRelationEN.mId, intMid);
}
else
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
}
clsGeneralTab2.LogErrorS2("clsSubjectRelationBL", "GetSubjectRelationObjBymId_Cache", strErrMsgForGetObjById, "", "");
throw new Exception(strErrMsgForGetObjById);
}

public static List<clsSubjectRelationEN> GetSubjectRelationObjList(string strWhereCond)
{
 List<clsSubjectRelationEN> arrObjList = new List<clsSubjectRelationEN>(); 
System.Data.DataTable objDT = null; 
 objDT = GetDataTable_SubjectRelationWs(strWhereCond);
if (objDT.Rows.Count == 0)
{
objDT = null;
return arrObjList;
}
foreach(DataRow objRow in objDT.Rows)
{
	clsSubjectRelationEN objSubjectRelationEN = new clsSubjectRelationEN();
objSubjectRelationEN.mId = Int32.Parse(objRow["mId"].ToString().Trim()); //流水号
objSubjectRelationEN.UserId = objRow["UserId"].ToString().Trim(); //用户ID
objSubjectRelationEN.LeaderId = objRow["LeaderId"].ToString().Trim(); //领导Id
objSubjectRelationEN.IsDirectLeader = com.taishsoft.common.clsTranslate.TransNullToBool_S(objRow["IsDirectLeader"].ToString().Trim()); //是否直接领导
objSubjectRelationEN.Memo = objRow["Memo"].ToString().Trim(); //备注
	arrObjList.Add(objSubjectRelationEN);
	}
objDT = null;
return arrObjList;
}

