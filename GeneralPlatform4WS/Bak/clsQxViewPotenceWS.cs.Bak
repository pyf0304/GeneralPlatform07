 ///生成绑定ListView的代码
 /// <summary>
 /// 函数功能:根据界面上查询控件中所设置内容查询表记录,
 ///			 并显示在ListView中。
 /// (AGC_CSV7.BusinessLogicEx.AutoGCPubFuncV6:GenBindListView)
 /// </summary>
public static int BindLv_QxViewPotence(System.Windows.Forms.ListView lvQxViewPotence, string strWhereCond)
{
//操作步骤:(共4步)
//	1、组合界面条件串；
//	2、根据条件串获取该表满足条件的DataTable；
//	3、设置ListView的列头信息
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
//		在本界面中是把状态显示在控件lblRecCount中。

System.Windows.Forms.ListViewItem lviQxViewPotence; 
ArrayList arrQxViewPotenceObjList;
//	2、根据条件串获取该表满足条件的DataTable；
arrQxViewPotenceObjList = new clsQxViewPotenceBL.GetQxViewPotenceObjList(strWhereCond);
//	3、设置ListView的列头信息
lvQxViewPotence.Items.Clear();//清除原来所有Item
lvQxViewPotence.Columns.Clear();//清除原来所有列头信息
lvQxViewPotence.Columns.Add("流水号", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxViewPotence.Columns.Add("界面编号", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxViewPotence.Columns.Add("项目Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxViewPotence.Columns.Add("权限ID", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxViewPotence.Columns.Add("等级", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxViewPotence.Columns.Add("备注", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxViewPotence.View = System.Windows.Forms.View.Details;
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
foreach (clsQxViewPotenceEN objQxViewPotenceEN in arrQxViewPotenceObjList)
{
lviQxViewPotence = new System.Windows.Forms.ListViewItem();
lviQxViewPotence.Tag = objQxViewPotenceEN.mId;
lviQxViewPotence.Text = objQxViewPotenceEN.mId.ToString();
lviQxViewPotence.SubItems.Add(objQxViewPotenceEN.Level.ToString());
lviQxViewPotence.SubItems.Add(objQxViewPotenceEN.Memo);
lvQxViewPotence.Items.Add(lviQxViewPotence);
}
//	4、设置记录数的状态,
//		在本界面中是把状态显示在控件txtRecCount中。
return arrQxViewPotenceObjList.Count;
}

 /// <summary>
 /// 检查对象字段值是否合法,1)检查是否可空;2)检查字段值长度是否超长,如果出错就抛出错误.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4WS_CheckPropertyNew)
 /// </summary>
public void CheckPropertyNew(clsQxViewPotenceEN objQxViewPotenceEN)
{
if (!Object.Equals(null, objQxViewPotenceEN.ViewId) && getStrLen(objQxViewPotenceEN.ViewId) > 8)
{
 throw new Exception("字段[界面编号]的长度不能超过8!");
}
if (!Object.Equals(null, objQxViewPotenceEN.QxPrjId) && getStrLen(objQxViewPotenceEN.QxPrjId) > 4)
{
 throw new Exception("字段[项目Id]的长度不能超过4!");
}
if (!Object.Equals(null, objQxViewPotenceEN.PotenceId) && getStrLen(objQxViewPotenceEN.PotenceId) > 8)
{
 throw new Exception("字段[权限ID]的长度不能超过8!");
}
if (!Object.Equals(null, objQxViewPotenceEN.Memo) && getStrLen(objQxViewPotenceEN.Memo) > 1000)
{
 throw new Exception("字段[备注]的长度不能超过1000!");
}
 objQxViewPotenceEN.IsCheckProperty = true;
 }

