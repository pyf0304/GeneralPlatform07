public static bool DelDataBaseTypesWs(List<string> arrDataBaseTypeId)
{
DataBaseTypeServiceSoapClient objDataBaseTypeService = GetDataBaseTypeServiceSoapClient();
try
{
string[] sstrDataBaseTypeId = (string[])(arrDataBaseTypeId.ToArray());
bool bolResult = objDataBaseTypeService.DataBaseType_DelDataBaseTypes(sstrDataBaseTypeId);
return bolResult;
