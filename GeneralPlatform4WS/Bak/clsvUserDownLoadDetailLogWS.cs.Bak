using System;
using System.Data;
using System.Data.SqlClient;
using System.Text;
using System.Collections;
using com.taishsoft.commdb;
using System.ServiceModel;
using GeneralPlatform4WS.ServiceReferencevUserDownLoadDetailLog;

namespace GeneralPlatform4WS
{
    /// <summary>
    /// vUserDownLoadDetailLog(vUserDownLoadDetailLog)
    /// </summary>
    public class clsvUserDownLoadDetailLogWS
    {
        private static vUserDownLoadDetailLogServiceSoapClient objvUserDownLoadDetailLogServiceSoapClient = null;
        /// <summary>
        /// 
        /// </summary>
        /// <returns></returns>
        public static vUserDownLoadDetailLogServiceSoapClient GetvUserDownLoadDetailLogServiceSoapClient()
        {
            if (objvUserDownLoadDetailLogServiceSoapClient == null)
            {
                BasicHttpBinding binding = new BasicHttpBinding();
                binding.Name = "vUserDownLoadDetailLogServiceSoap";
                binding.CloseTimeout = new System.TimeSpan(6000);
                String strServiceUrl = String.Empty;
                if (clsSysPara.bolIsLocalHost == false)
                {
                    strServiceUrl = String.Format("http://{0}/{1}/vUserDownLoadDetailLogService.asmx", clsSysPara.CurrIPAddressAndPort, clsSysPara.CurrPrx);
                }
                else
                {
                    strServiceUrl = String.Format("http://{0}/vUserDownLoadDetailLogService.asmx", clsSysPara.strCurrIPAddressAndPort_Local);
                }
                EndpointAddress address = new EndpointAddress(strServiceUrl);
                return new vUserDownLoadDetailLogServiceSoapClient(binding, address);
            }
            else
            {
                return objvUserDownLoadDetailLogServiceSoapClient;
            }
        }

        public clsvUserDownLoadDetailLogWS()
        {
        }


        ///绑定下拉框的函数代码

        ///生成绑定ListView的代码
        /// <summary>
        /// 函数功能：根据界面上查询控件中所设置内容查询表记录，
        ///			 并显示在ListView中。
        /// </summary>
        public static int BindLv_vUserDownLoadDetailLog(System.Windows.Forms.ListView lvvUserDownLoadDetailLog, string strWhereCond)
        {
            //操作步骤：(共4步)
            //	1、组合界面条件串；
            //	2、根据条件串获取该表满足条件的DataTable；
            //	3、设置ListView的列头信息
            //	4、设置ListView的Item信息。即把所有记录显示在ListView中
            //		在本界面中是把状态显示在控件lblRecCount中。

            System.Windows.Forms.ListViewItem lvivUserDownLoadDetailLog;
            ArrayList arrvUserDownLoadDetailLogObjList;
            //	2、根据条件串获取该表满足条件的DataTable；
            arrvUserDownLoadDetailLogObjList = GetvUserDownLoadDetailLogObjList(strWhereCond);
            //	3、设置ListView的列头信息
            lvvUserDownLoadDetailLog.Items.Clear();//清除原来所有Item
            lvvUserDownLoadDetailLog.Columns.Clear();//清除原来所有列头信息
            lvvUserDownLoadDetailLog.Columns.Add("流水号", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("用户下载日志Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("工程站点Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("工程站点名", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("项目Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("工程名", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("用户ID", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("文件名", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("版本", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("下载日期", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("是否成功", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("日志信息", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("Ftp服务器", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("Ftp用户Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("Ftp用户口令", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.Columns.Add("备注", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUserDownLoadDetailLog.View = System.Windows.Forms.View.Details;
            //	4、设置ListView的Item信息。即把所有记录显示在ListView中
            foreach (clsvUserDownLoadDetailLogEN objvUserDownLoadDetailLogEN in arrvUserDownLoadDetailLogObjList)
            {
                lvivUserDownLoadDetailLog = new System.Windows.Forms.ListViewItem();
                lvivUserDownLoadDetailLog.Tag = objvUserDownLoadDetailLogEN.mId;
                lvivUserDownLoadDetailLog.Text = objvUserDownLoadDetailLogEN.mId.ToString();
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.UserDownLoadLogId);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.PrjSiteId);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.PrjSiteName);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.PrjId);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.PrjName);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.UserId);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.FileName);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.Version);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.DownLownDate);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.IsSuccess.ToString());
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.LogInfo);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.FtpServer);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.FtpUserId);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.FtpUserPassword);
                lvivUserDownLoadDetailLog.SubItems.Add(objvUserDownLoadDetailLogEN.Memo);
                lvvUserDownLoadDetailLog.Items.Add(lvivUserDownLoadDetailLog);
            }
            //	4、设置记录数的状态，
            //		在本界面中是把状态显示在控件txtRecCount中。
            return arrvUserDownLoadDetailLogObjList.Count;
        }

        public static DataTable GetDataTable_vUserDownLoadDetailLogWs(string strWhereCond)
        {
            vUserDownLoadDetailLogServiceSoapClient objvUserDownLoadDetailLogService = GetvUserDownLoadDetailLogServiceSoapClient();
            DataSet objDS = null;
            try
            {
                objDS = objvUserDownLoadDetailLogService.vUserDownLoadDetailLog_GetDataSet(strWhereCond);
                DataTable objDT = objDS.Tables[0];
                return objDT;
            }
            catch (Exception objException)
            {
                throw new Exception("获取表:vUserDownLoadDetailLog 数据出错！\r\n" + objException.Message);
            }
        }


        public static bool GetvUserDownLoadDetailLogWs(ref clsvUserDownLoadDetailLogEN objvUserDownLoadDetailLogEN)
        {
            vUserDownLoadDetailLogServiceSoapClient objvUserDownLoadDetailLogService = GetvUserDownLoadDetailLogServiceSoapClient();
            bool bolResult = objvUserDownLoadDetailLogService.vUserDownLoadDetailLog_GetvUserDownLoadDetailLog(ref objvUserDownLoadDetailLogEN);
            return bolResult;
        }

        public static ArrayList GetvUserDownLoadDetailLogObjList(string strCondition)
        {
            ArrayList arrObjList = new ArrayList();
            System.Data.DataTable objDT = null;
            objDT = GetDataTable_vUserDownLoadDetailLogWs(strCondition);
            if (objDT.Rows.Count == 0)
            {
                objDT = null;
                return arrObjList;
            }
            foreach (DataRow objRow in objDT.Rows)
            {
                clsvUserDownLoadDetailLogEN objvUserDownLoadDetailLogEN = new clsvUserDownLoadDetailLogEN();
                objvUserDownLoadDetailLogEN.mId = Int32.Parse(objRow["mId"].ToString().Trim()); //流水号
                objvUserDownLoadDetailLogEN.UserDownLoadLogId = objRow["UserDownLoadLogId"].ToString().Trim(); //用户下载日志Id
                objvUserDownLoadDetailLogEN.PrjSiteId = objRow["PrjSiteId"].ToString().Trim(); //工程站点Id
                objvUserDownLoadDetailLogEN.PrjSiteName = objRow["PrjSiteName"].ToString().Trim(); //工程站点名
                objvUserDownLoadDetailLogEN.PrjId = objRow["PrjId"].ToString().Trim(); //项目Id
                objvUserDownLoadDetailLogEN.PrjName = objRow["PrjName"].ToString().Trim(); //工程名
                objvUserDownLoadDetailLogEN.UserId = objRow["UserId"].ToString().Trim(); //用户ID
                objvUserDownLoadDetailLogEN.FileName = objRow["FileName"].ToString().Trim(); //文件名
                objvUserDownLoadDetailLogEN.Version = objRow["Version"].ToString().Trim(); //版本
                objvUserDownLoadDetailLogEN.DownLownDate = objRow["DownLownDate"].ToString().Trim(); //下载日期
                objvUserDownLoadDetailLogEN.IsSuccess = com.taishsoft.common.clsTranslate.TransNullToBool_S(objRow["IsSuccess"].ToString().Trim()); //是否成功
                objvUserDownLoadDetailLogEN.LogInfo = objRow["LogInfo"].ToString().Trim(); //日志信息
                objvUserDownLoadDetailLogEN.FtpServer = objRow["FtpServer"].ToString().Trim(); //Ftp服务器
                objvUserDownLoadDetailLogEN.FtpUserId = objRow["FtpUserId"].ToString().Trim(); //Ftp用户Id
                objvUserDownLoadDetailLogEN.FtpUserPassword = objRow["FtpUserPassword"].ToString().Trim(); //Ftp用户口令
                objvUserDownLoadDetailLogEN.Memo = objRow["Memo"].ToString().Trim(); //备注
                arrObjList.Add(objvUserDownLoadDetailLogEN);
            }
            objDT = null;
            return arrObjList;
        }

        public static bool IsExistRecordWs(string strCondition)
        {
            //检测记录是否存在
            vUserDownLoadDetailLogServiceSoapClient objvUserDownLoadDetailLogService = GetvUserDownLoadDetailLogServiceSoapClient();
            bool bolIsExist = objvUserDownLoadDetailLogService.vUserDownLoadDetailLog_IsExistRecord(strCondition);
            return bolIsExist;
        }

        public static bool IsExistWs(long lngmId)
        {
            //检测记录是否存在
            vUserDownLoadDetailLogServiceSoapClient objvUserDownLoadDetailLogService = GetvUserDownLoadDetailLogServiceSoapClient();
            bool bolIsExist = objvUserDownLoadDetailLogService.vUserDownLoadDetailLog_IsExist(lngmId);
            return bolIsExist;
        }
    }
