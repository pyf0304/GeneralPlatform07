 /// <summary>
 /// 根据关键字获取相关名称, 从缓存的对象列表中获取.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecNameByKey_Cache)
 /// </summary>
 /// <param name = "strPotenceTypeId">所给的关键字</param>
 /// <returns>根据关键字获取的名称</returns>
public static string GetPotenceTypeNameByPotenceTypeId_Cache(string strPotenceTypeId)
{
if (string.IsNullOrEmpty(strPotenceTypeId) == true) return "";
string strWhereCond = string.Format("1 = 1 order by PotenceTypeId");
if (arrvQxPotenceTypeObjLst_Cache == null)
{
arrvQxPotenceTypeObjLst_Cache = clsvQxPotenceTypeWS.GetvQxPotenceTypeObjList(strWhereCond);
}
int intStart = 0;
int intEnd = arrvQxPotenceTypeObjLst_Cache.Count - 1;
int intMid = 0;
clsvQxPotenceTypeEN objvQxPotenceTypeEN = null;
while (intEnd >= intStart)
{
intMid = (intStart + intEnd) / 2;
objvQxPotenceTypeEN = arrvQxPotenceTypeObjLst_Cache[intMid];
if (objvQxPotenceTypeEN.PotenceTypeId == strPotenceTypeId)
{
intFindFailCount = 0;
return objvQxPotenceTypeEN.PotenceTypeName;
}
else if (objvQxPotenceTypeEN.PotenceTypeId.CompareTo(strPotenceTypeId) > 0)
{
intEnd = intMid - 1;
}
else
{
intStart = intMid + 1;
}
}
intFindFailCount++;
// 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
arrvQxPotenceTypeObjLst_Cache = null;
if (intFindFailCount == 1) return GetPotenceTypeNameByPotenceTypeId_Cache(strPotenceTypeId);
string strErrMsgForGetObjById = string.Format("在vQxPotenceType对象缓存列表中,找不到记录[PotenceTypeId = {0}][intFindFailCount = {1}](函数:GetPotenceTypeNameByPotenceTypeId_Cache)", strPotenceTypeId, intFindFailCount);
if (objvQxPotenceTypeEN != null)
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objvQxPotenceTypeEN.PotenceTypeId, intMid);
}
else
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
}
clsGeneralTab2.LogErrorS2("clsvQxPotenceTypeBL", "GetPotenceTypeNameByPotenceTypeId_Cache", strErrMsgForGetObjById, "", "");
throw new Exception(strErrMsgForGetObjById);
}

