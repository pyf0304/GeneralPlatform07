 /// <summary>
 /// 根据关键字获取相关对象, 从缓存的对象列表中获取.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecObjByKey_Cache)
 /// </summary>
 /// <param name = "lngmId">所给的关键字</param>
 /// <returns>根据关键字获取的对象</returns>
public static clsQxUserMenuDetailEN GetQxUserMenuDetailObjBymId_Cache(long lngmId)
{
string strWhereCond = string.Format("1 = 1 order by mId");
if (arrQxUserMenuDetailObjLst_Cache == null)
{
arrQxUserMenuDetailObjLst_Cache = clsQxUserMenuDetailWS.GetQxUserMenuDetailObjList(strWhereCond);
}
int intStart = 0;
int intEnd = arrQxUserMenuDetailObjLst_Cache.Count - 1;
int intMid = 0;
clsQxUserMenuDetailEN objQxUserMenuDetailEN = null;
while (intEnd >= intStart)
{
intMid = (intStart + intEnd) / 2;
objQxUserMenuDetailEN = arrQxUserMenuDetailObjLst_Cache[intMid];
if (objQxUserMenuDetailEN.mId == lngmId)
{
intFindFailCount = 0;
return objQxUserMenuDetailEN;
}
else if (objQxUserMenuDetailEN.mId.CompareTo(lngmId) > 0)
{
intEnd = intMid - 1;
}
else
{
intStart = intMid + 1;
}
}
intFindFailCount++;
// 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
arrQxUserMenuDetailObjLst_Cache = null;
if (intFindFailCount == 1) return GetQxUserMenuDetailObjBymId_Cache(lngmId);
string strErrMsgForGetObjById = string.Format("在QxUserMenuDetail对象缓存列表中,找不到记录[mId = {0}][intFindFailCount = {1}](函数:GetQxUserMenuDetailObjBymId_Cache)", lngmId, intFindFailCount);
if (objQxUserMenuDetailEN != null)
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objQxUserMenuDetailEN.mId, intMid);
}
else
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
}
clsGeneralTab2.LogErrorS2("clsQxUserMenuDetailBL", "GetQxUserMenuDetailObjBymId_Cache", strErrMsgForGetObjById, "", "");
throw new Exception(strErrMsgForGetObjById);
}

public static List<clsQxUserMenuDetailEN> GetQxUserMenuDetailObjList(string strWhereCond)
{
 List<clsQxUserMenuDetailEN> arrObjList = new List<clsQxUserMenuDetailEN>(); 
System.Data.DataTable objDT = null; 
 objDT = GetDataTable_QxUserMenuDetailWs(strWhereCond);
if (objDT.Rows.Count == 0)
{
objDT = null;
return arrObjList;
}
foreach(DataRow objRow in objDT.Rows)
{
	clsQxUserMenuDetailEN objQxUserMenuDetailEN = new clsQxUserMenuDetailEN();
objQxUserMenuDetailEN.mId = Int32.Parse(objRow["mId"].ToString().Trim()); //流水号
objQxUserMenuDetailEN.MenuId = objRow["MenuId"].ToString().Trim(); //菜单Id
objQxUserMenuDetailEN.MenuName = objRow["MenuName"].ToString().Trim(); //菜单名
objQxUserMenuDetailEN.IsDisp = com.taishsoft.common.clsTranslate.TransNullToBool_S(objRow["IsDisp"].ToString().Trim()); //是否显示
objQxUserMenuDetailEN.UpMenuId = objRow["UpMenuId"].ToString().Trim(); //上级菜单Id
objQxUserMenuDetailEN.LinkFile = objRow["LinkFile"].ToString().Trim(); //链接文件
objQxUserMenuDetailEN.ImgFile = objRow["ImgFile"].ToString().Trim(); //图像文件
objQxUserMenuDetailEN.IsCustomMenu = com.taishsoft.common.clsTranslate.TransNullToBool_S(objRow["IsCustomMenu"].ToString().Trim()); //是否定制菜单
objQxUserMenuDetailEN.UserId = objRow["UserId"].ToString().Trim(); //用户ID
objQxUserMenuDetailEN.QxPrjId = objRow["QxPrjId"].ToString().Trim(); //项目Id
objQxUserMenuDetailEN.OrderNum = Int32.Parse(objRow["OrderNum"].ToString().Trim()); //排序号
objQxUserMenuDetailEN.Memo = objRow["Memo"].ToString().Trim(); //备注
	arrObjList.Add(objQxUserMenuDetailEN);
	}
objDT = null;
return arrObjList;
}

