 /// <summary>
 /// 根据关键字获取相关对象, 从缓存的对象列表中获取.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecObjByKey_Cache)
 /// </summary>
 /// <param name = "strUserId">所给的关键字</param>
 /// <returns>根据关键字获取的对象</returns>
public static clsvQxUsersEN GetvQxUsersObjByUserId_Cache(string strUserId)
{
if (string.IsNullOrEmpty(strUserId) == true) return null;
string strWhereCond = string.Format("1 = 1 order by UserId");
if (arrvQxUsersObjLst_Cache == null)
{
arrvQxUsersObjLst_Cache = clsvQxUsersWS.GetvQxUsersObjList(strWhereCond);
}
int intStart = 0;
int intEnd = arrvQxUsersObjLst_Cache.Count - 1;
int intMid = 0;
clsvQxUsersEN objvQxUsersEN = null;
while (intEnd >= intStart)
{
intMid = (intStart + intEnd) / 2;
objvQxUsersEN = arrvQxUsersObjLst_Cache[intMid];
if (objvQxUsersEN.UserId == strUserId)
{
intFindFailCount = 0;
return objvQxUsersEN;
}
else if (objvQxUsersEN.UserId.CompareTo(strUserId) > 0)
{
intEnd = intMid - 1;
}
else
{
intStart = intMid + 1;
}
}
intFindFailCount++;
// 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
arrvQxUsersObjLst_Cache = null;
if (intFindFailCount == 1) return GetvQxUsersObjByUserId_Cache(strUserId);
string strErrMsgForGetObjById = string.Format("在vQxUsers对象缓存列表中,找不到记录[UserId = {0}][intFindFailCount = {1}](函数:GetvQxUsersObjByUserId_Cache)", strUserId, intFindFailCount);
if (objvQxUsersEN != null)
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objvQxUsersEN.UserId, intMid);
}
else
{
strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
}
clsGeneralTab2.LogErrorS2("clsvQxUsersBL", "GetvQxUsersObjByUserId_Cache", strErrMsgForGetObjById, "", "");
throw new Exception(strErrMsgForGetObjById);
}

public static List<clsvQxUsersEN> GetvQxUsersObjList(string strWhereCond)
{
 List<clsvQxUsersEN> arrObjList = new List<clsvQxUsersEN>(); 
System.Data.DataTable objDT = null; 
 objDT = GetDataTable_vQxUsersWs(strWhereCond);
if (objDT.Rows.Count == 0)
{
objDT = null;
return arrObjList;
}
foreach(DataRow objRow in objDT.Rows)
{
	clsvQxUsersEN objvQxUsersEN = new clsvQxUsersEN();
objvQxUsersEN.UserId = objRow["UserId"].ToString().Trim(); //用户ID
objvQxUsersEN.UserName = objRow["UserName"].ToString().Trim(); //用户名
objvQxUsersEN.DepartmentId = objRow["DepartmentId"].ToString().Trim(); //部门Id
objvQxUsersEN.DepartmentName = objRow["DepartmentName"].ToString().Trim(); //部门名
objvQxUsersEN.DepartmentAbbrName = objRow["DepartmentAbbrName"].ToString().Trim(); //名称缩写
objvQxUsersEN.DepartmentTypeId = objRow["DepartmentTypeId"].ToString().Trim(); //部门类型ID
objvQxUsersEN.DepartmentTypeName = objRow["DepartmentTypeName"].ToString().Trim(); //部门类型名
objvQxUsersEN.UpDepartmentId = objRow["UpDepartmentId"].ToString().Trim(); //所属部门号
objvQxUsersEN.UpDepartmentName = objRow["UpDepartmentName"].ToString().Trim(); //上级部门
objvQxUsersEN.UserStateId = objRow["UserStateId"].ToString().Trim(); //用户状态Id
objvQxUsersEN.UserStateName = objRow["UserStateName"].ToString().Trim(); //用户状态名
objvQxUsersEN.EffectiveDate = objRow["EffectiveDate"].ToString().Trim(); //有效日期
objvQxUsersEN.Password = objRow["Password"].ToString().Trim(); //口令
objvQxUsersEN.id_College = objRow["id_College"].ToString().Trim(); //学院流水号
objvQxUsersEN.EffitiveBeginDate = objRow["EffitiveBeginDate"].ToString().Trim(); //有效开始日期
objvQxUsersEN.EffitiveEndDate = objRow["EffitiveEndDate"].ToString().Trim(); //有效结束日期
objvQxUsersEN.StuTeacherId = objRow["StuTeacherId"].ToString().Trim(); //学工号
objvQxUsersEN.IdentityID = objRow["IdentityID"].ToString().Trim(); //身份编号
objvQxUsersEN.IdentityDesc = objRow["IdentityDesc"].ToString().Trim(); //身份描述
objvQxUsersEN.UpdDate = objRow["UpdDate"].ToString().Trim(); //修改日期
objvQxUsersEN.UpdUser = objRow["UpdUser"].ToString().Trim(); //修改用户
objvQxUsersEN.Memo = objRow["Memo"].ToString().Trim(); //备注
	arrObjList.Add(objvQxUsersEN);
	}
objDT = null;
return arrObjList;
}

