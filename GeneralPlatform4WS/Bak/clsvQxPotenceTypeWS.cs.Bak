public static List<clsvQxPotenceTypeEN> GetvQxPotenceTypeObjList(string strWhereCond)
{
 List<clsvQxPotenceTypeEN> arrObjList = new List<clsvQxPotenceTypeEN>(); 
System.Data.DataTable objDT = null; 
 objDT = GetDataTable_vQxPotenceTypeWs(strWhereCond);
if (objDT.Rows.Count == 0)
{
objDT = null;
return arrObjList;
}
foreach(DataRow objRow in objDT.Rows)
{
	clsvQxPotenceTypeEN objvQxPotenceTypeEN = new clsvQxPotenceTypeEN();
objvQxPotenceTypeEN.PotenceTypeId = objRow["PotenceTypeId"].ToString().Trim(); //权限类型Id
objvQxPotenceTypeEN.PotenceTypeName = objRow["PotenceTypeName"].ToString().Trim(); //权限类型名
objvQxPotenceTypeEN.QxPrjId = objRow["QxPrjId"].ToString().Trim(); //项目Id
objvQxPotenceTypeEN.PrjName = objRow["PrjName"].ToString().Trim(); //工程名
objvQxPotenceTypeEN.Memo = objRow["Memo"].ToString().Trim(); //备注
objvQxPotenceTypeEN.UpdDate = objRow["UpdDate"].ToString().Trim(); //修改日期
objvQxPotenceTypeEN.UpdUserId = objRow["UpdUserId"].ToString().Trim(); //修改用户Id
	arrObjList.Add(objvQxPotenceTypeEN);
	}
objDT = null;
return arrObjList;
}

