public static List<clsQxDepartmentTypeEN> GetQxDepartmentTypeObjList(string strWhereCond)
{
 List<clsQxDepartmentTypeEN> arrObjList = new List<clsQxDepartmentTypeEN>(); 
System.Data.DataTable objDT = null; 
 objDT = GetDataTable_QxDepartmentTypeWs(strWhereCond);
if (objDT.Rows.Count == 0)
{
objDT = null;
return arrObjList;
}
foreach(DataRow objRow in objDT.Rows)
{
	clsQxDepartmentTypeEN objQxDepartmentTypeEN = new clsQxDepartmentTypeEN();
objQxDepartmentTypeEN.DepartmentTypeId = objRow["DepartmentTypeId"].ToString().Trim(); //部门类型ID
objQxDepartmentTypeEN.DepartmentTypeName = objRow["DepartmentTypeName"].ToString().Trim(); //部门类型名
objQxDepartmentTypeEN.Memo = objRow["Memo"].ToString().Trim(); //备注
	arrObjList.Add(objQxDepartmentTypeEN);
	}
objDT = null;
return arrObjList;
}

