        /// <summary>
        /// 根据关键字获取相关名称, 从缓存的对象列表中获取.
        /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecNameByKey_Cache)
        /// </summary>
        /// <param name = "strMenuId">所给的关键字</param>
        /// <returns>根据关键字获取的名称</returns>
        public static string GetMenuNameByMenuId_Cache(string strMenuId)
        {
            if (string.IsNullOrEmpty(strMenuId) == true) return "";
            string strWhereCond = string.Format("1 = 1 order by MenuId");
            if (arrPrjMenusObjLst_Cache == null)
            {
                arrPrjMenusObjLst_Cache = clsPrjMenusWS.GetPrjMenusObjList(strWhereCond);
            }
            int intStart = 0;
            int intEnd = arrPrjMenusObjLst_Cache.Count - 1;
            int intMid = 0;
            clsPrjMenusEN objPrjMenusEN = null;
            while (intEnd >= intStart)
            {
                intMid = (intStart + intEnd) / 2;
                objPrjMenusEN = arrPrjMenusObjLst_Cache[intMid];
                if (objPrjMenusEN.MenuId == strMenuId)
                {
                    intFindFailCount = 0;
                    return objPrjMenusEN.MenuName;
                }
                else if (objPrjMenusEN.MenuId.CompareTo(strMenuId) > 0)
                {
                    intEnd = intMid - 1;
                }
                else
                {
                    intStart = intMid + 1;
                }
            }
            intFindFailCount++;
            // 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
            arrPrjMenusObjLst_Cache = null;
            if (intFindFailCount == 1) return GetMenuNameByMenuId_Cache(strMenuId);
            string strErrMsgForGetObjById = string.Format("在PrjMenus对象缓存列表中,找不到记录[MenuId = {0}][intFindFailCount = {1}](函数:GetMenuNameByMenuId_Cache)", strMenuId, intFindFailCount);
            if (objPrjMenusEN != null)
            {
                strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objPrjMenusEN.MenuId, intMid);
            }
            else
            {
                strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
            }
            clsGeneralTab2.LogErrorS2("clsPrjMenusBL", "GetMenuNameByMenuId_Cache", strErrMsgForGetObjById, "", "");
            throw new Exception(strErrMsgForGetObjById);
        }

        /// <summary>
        /// 根据关键字获取相关对象, 从缓存的对象列表中获取.
        /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecObjByKey_Cache)
        /// </summary>
        /// <param name = "strMenuId">所给的关键字</param>
        /// <returns>根据关键字获取的对象</returns>
        public static clsPrjMenusEN GetPrjMenusObjByMenuId_Cache(string strMenuId)
        {
            if (string.IsNullOrEmpty(strMenuId) == true) return null;
            string strWhereCond = string.Format("1 = 1 order by MenuId");
            if (arrPrjMenusObjLst_Cache == null)
            {
                arrPrjMenusObjLst_Cache = clsPrjMenusWS.GetPrjMenusObjList(strWhereCond);
            }
            int intStart = 0;
            int intEnd = arrPrjMenusObjLst_Cache.Count - 1;
            int intMid = 0;
            clsPrjMenusEN objPrjMenusEN = null;
            while (intEnd >= intStart)
            {
                intMid = (intStart + intEnd) / 2;
                objPrjMenusEN = arrPrjMenusObjLst_Cache[intMid];
                if (objPrjMenusEN.MenuId == strMenuId)
                {
                    intFindFailCount = 0;
                    return objPrjMenusEN;
                }
                else if (objPrjMenusEN.MenuId.CompareTo(strMenuId) > 0)
                {
                    intEnd = intMid - 1;
                }
                else
                {
                    intStart = intMid + 1;
                }
            }
            intFindFailCount++;
            // 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
            arrPrjMenusObjLst_Cache = null;
            if (intFindFailCount == 1) return GetPrjMenusObjByMenuId_Cache(strMenuId);
            string strErrMsgForGetObjById = string.Format("在PrjMenus对象缓存列表中,找不到记录[MenuId = {0}][intFindFailCount = {1}](函数:GetPrjMenusObjByMenuId_Cache)", strMenuId, intFindFailCount);
            if (objPrjMenusEN != null)
            {
                strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objPrjMenusEN.MenuId, intMid);
            }
            else
            {
                strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
            }
            clsGeneralTab2.LogErrorS2("clsPrjMenusBL", "GetPrjMenusObjByMenuId_Cache", strErrMsgForGetObjById, "", "");
            throw new Exception(strErrMsgForGetObjById);
        }

        public static List<clsPrjMenusEN> GetPrjMenusObjList(string strWhereCond)
        {
            List<clsPrjMenusEN> arrObjList = new List<clsPrjMenusEN>();
            System.Data.DataTable objDT = null;
            objDT = GetDataTable_PrjMenusWs(strWhereCond);
            if (objDT.Rows.Count == 0)
            {
                objDT = null;
                return arrObjList;
            }
            foreach (DataRow objRow in objDT.Rows)
            {
                clsPrjMenusEN objPrjMenusEN = new clsPrjMenusEN();
                objPrjMenusEN.MenuId = objRow["MenuId"].ToString().Trim(); //菜单Id
                objPrjMenusEN.MenuName = objRow["MenuName"].ToString().Trim(); //菜单名
                objPrjMenusEN.PrjId = objRow["PrjId"].ToString().Trim(); //项目Id
                objPrjMenusEN.UpMenuId = objRow["UpMenuId"].ToString().Trim(); //上级菜单Id
                objPrjMenusEN.LinkFile = objRow["LinkFile"].ToString().Trim(); //链接文件
                objPrjMenusEN.qsParameters = objRow["qsParameters"].ToString().Trim(); //qs参数
                objPrjMenusEN.ImgFile = objRow["ImgFile"].ToString().Trim(); //图像文件
                objPrjMenusEN.RoleId = objRow["RoleId"].ToString().Trim(); //角色Id
                objPrjMenusEN.OrderNum = Int32.Parse(objRow["OrderNum"].ToString().Trim()); //排序号
                objPrjMenusEN.IsLeafNode = com.taishsoft.common.clsTranslate.TransNullToBool_S(objRow["IsLeafNode"].ToString().Trim()); //是否叶子
                objPrjMenusEN.MenuSetId = objRow["MenuSetId"].ToString().Trim(); //菜单集Id
                objPrjMenusEN.MenuTitle = objRow["MenuTitle"].ToString().Trim(); //菜单标题
                objPrjMenusEN.PageDispModeId = objRow["PageDispModeId"].ToString().Trim(); //页面显示模式Id
                objPrjMenusEN.InUse = com.taishsoft.common.clsTranslate.TransNullToBool_S(objRow["InUse"].ToString().Trim()); //是否在用
                objPrjMenusEN.UpdDate = objRow["UpdDate"].ToString().Trim(); //修改日期
                objPrjMenusEN.UpdUserId = objRow["UpdUserId"].ToString().Trim(); //修改用户Id
                objPrjMenusEN.Memo = objRow["Memo"].ToString().Trim(); //备注
                arrObjList.Add(objPrjMenusEN);
            }
            objDT = null;
            return arrObjList;
        }

