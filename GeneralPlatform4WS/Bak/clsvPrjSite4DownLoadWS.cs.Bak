using System;
using System.Data;
using System.Data.SqlClient;
using System.Text;
using System.Collections;
using com.taishsoft.commdb;
using System.ServiceModel;
using GeneralPlatform4WS.ServiceReferencevPrjSite4DownLoad;

namespace GeneralPlatform4WS
{
    /// <summary>
    /// vPrjSite4DownLoad(vPrjSite4DownLoad)
    /// </summary>
    public class clsvPrjSite4DownLoadWS
    {
        private static vPrjSite4DownLoadServiceSoapClient objvPrjSite4DownLoadServiceSoapClient = null;
        /// <summary>
        /// 
        /// </summary>
        /// <returns></returns>
        public static vPrjSite4DownLoadServiceSoapClient GetvPrjSite4DownLoadServiceSoapClient()
        {
            if (objvPrjSite4DownLoadServiceSoapClient == null)
            {
                BasicHttpBinding binding = new BasicHttpBinding();
                binding.Name = "vPrjSite4DownLoadServiceSoap";
                binding.CloseTimeout = new System.TimeSpan(6000);
                String strServiceUrl = String.Empty;
                if (clsSysPara.bolIsLocalHost == false)
                {
                    strServiceUrl = String.Format("http://{0}/{1}/vPrjSite4DownLoadService.asmx", clsSysPara.CurrIPAddressAndPort, clsSysPara.CurrPrx);
                }
                else
                {
                    strServiceUrl = String.Format("http://{0}/vPrjSite4DownLoadService.asmx", clsSysPara.strCurrIPAddressAndPort_Local);
                }
                EndpointAddress address = new EndpointAddress(strServiceUrl);
                return new vPrjSite4DownLoadServiceSoapClient(binding, address);
            }
            else
            {
                return objvPrjSite4DownLoadServiceSoapClient;
            }
        }

        public clsvPrjSite4DownLoadWS()
        {
        }


        ///绑定下拉框的函数代码

        ///生成绑定ListView的代码
        /// <summary>
        /// 函数功能：根据界面上查询控件中所设置内容查询表记录，
        ///			 并显示在ListView中。
        /// </summary>
        public static int BindLv_vPrjSite4DownLoad(System.Windows.Forms.ListView lvvPrjSite4DownLoad, string strWhereCond)
        {
            //操作步骤：(共4步)
            //	1、组合界面条件串；
            //	2、根据条件串获取该表满足条件的DataTable；
            //	3、设置ListView的列头信息
            //	4、设置ListView的Item信息。即把所有记录显示在ListView中
            //		在本界面中是把状态显示在控件lblRecCount中。

            System.Windows.Forms.ListViewItem lvivPrjSite4DownLoad;
            ArrayList arrvPrjSite4DownLoadObjList;
            //	2、根据条件串获取该表满足条件的DataTable；
            arrvPrjSite4DownLoadObjList = GetvPrjSite4DownLoadObjList(strWhereCond);
            //	3、设置ListView的列头信息
            lvvPrjSite4DownLoad.Items.Clear();//清除原来所有Item
            lvvPrjSite4DownLoad.Columns.Clear();//清除原来所有列头信息
            lvvPrjSite4DownLoad.Columns.Add("工程站点Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvPrjSite4DownLoad.Columns.Add("工程站点名", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvPrjSite4DownLoad.Columns.Add("项目Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvPrjSite4DownLoad.Columns.Add("工程名", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvPrjSite4DownLoad.Columns.Add("Ftp服务器", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvPrjSite4DownLoad.Columns.Add("Ftp用户Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvPrjSite4DownLoad.Columns.Add("Ftp用户口令", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvPrjSite4DownLoad.Columns.Add("修改用户Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvPrjSite4DownLoad.Columns.Add("UpdDate", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvPrjSite4DownLoad.Columns.Add("备注", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvPrjSite4DownLoad.View = System.Windows.Forms.View.Details;
            //	4、设置ListView的Item信息。即把所有记录显示在ListView中
            foreach (clsvPrjSite4DownLoadEN objvPrjSite4DownLoadEN in arrvPrjSite4DownLoadObjList)
            {
                lvivPrjSite4DownLoad = new System.Windows.Forms.ListViewItem();
                lvivPrjSite4DownLoad.Tag = objvPrjSite4DownLoadEN.PrjSiteId;
                lvivPrjSite4DownLoad.Text = objvPrjSite4DownLoadEN.PrjSiteId.ToString();
                lvivPrjSite4DownLoad.SubItems.Add(objvPrjSite4DownLoadEN.PrjSiteName);
                lvivPrjSite4DownLoad.SubItems.Add(objvPrjSite4DownLoadEN.PrjId);
                lvivPrjSite4DownLoad.SubItems.Add(objvPrjSite4DownLoadEN.PrjName);
                lvivPrjSite4DownLoad.SubItems.Add(objvPrjSite4DownLoadEN.FtpServer);
                lvivPrjSite4DownLoad.SubItems.Add(objvPrjSite4DownLoadEN.FtpUserId);
                lvivPrjSite4DownLoad.SubItems.Add(objvPrjSite4DownLoadEN.FtpUserPassword);
                lvivPrjSite4DownLoad.SubItems.Add(objvPrjSite4DownLoadEN.UpdUserId);
                lvivPrjSite4DownLoad.SubItems.Add(objvPrjSite4DownLoadEN.UpdDate);
                lvivPrjSite4DownLoad.SubItems.Add(objvPrjSite4DownLoadEN.Memo);
                lvvPrjSite4DownLoad.Items.Add(lvivPrjSite4DownLoad);
            }
            //	4、设置记录数的状态，
            //		在本界面中是把状态显示在控件txtRecCount中。
            return arrvPrjSite4DownLoadObjList.Count;
        }

        public static DataTable GetDataTable_vPrjSite4DownLoadWs(string strWhereCond)
        {
            vPrjSite4DownLoadServiceSoapClient objvPrjSite4DownLoadService = GetvPrjSite4DownLoadServiceSoapClient();
            DataSet objDS = null;
            try
            {
                objDS = objvPrjSite4DownLoadService.vPrjSite4DownLoad_GetDataSet(strWhereCond);
                DataTable objDT = objDS.Tables[0];
                return objDT;
            }
            catch (Exception objException)
            {
                throw new Exception("获取表:vPrjSite4DownLoad 数据出错！\r\n" + objException.Message);
            }
        }

        public static bool GetvPrjSite4DownLoadWs(ref clsvPrjSite4DownLoadEN objvPrjSite4DownLoadEN)
        {
            vPrjSite4DownLoadServiceSoapClient objvPrjSite4DownLoadService = GetvPrjSite4DownLoadServiceSoapClient();
            bool bolResult = objvPrjSite4DownLoadService.vPrjSite4DownLoad_GetvPrjSite4DownLoad(ref objvPrjSite4DownLoadEN);
            return bolResult;
        }

        public static ArrayList GetvPrjSite4DownLoadObjList(string strCondition)
        {
            ArrayList arrObjList = new ArrayList();
            System.Data.DataTable objDT = null;
            objDT = GetDataTable_vPrjSite4DownLoadWs(strCondition);
            if (objDT.Rows.Count == 0)
            {
                objDT = null;
                return arrObjList;
            }
            foreach (DataRow objRow in objDT.Rows)
            {
                clsvPrjSite4DownLoadEN objvPrjSite4DownLoadEN = new clsvPrjSite4DownLoadEN();
                objvPrjSite4DownLoadEN.PrjSiteId = objRow["PrjSiteId"].ToString().Trim(); //工程站点Id
                objvPrjSite4DownLoadEN.PrjSiteName = objRow["PrjSiteName"].ToString().Trim(); //工程站点名
                objvPrjSite4DownLoadEN.PrjId = objRow["PrjId"].ToString().Trim(); //项目Id
                objvPrjSite4DownLoadEN.PrjName = objRow["PrjName"].ToString().Trim(); //工程名
                objvPrjSite4DownLoadEN.FtpServer = objRow["FtpServer"].ToString().Trim(); //Ftp服务器
                objvPrjSite4DownLoadEN.FtpUserId = objRow["FtpUserId"].ToString().Trim(); //Ftp用户Id
                objvPrjSite4DownLoadEN.FtpUserPassword = objRow["FtpUserPassword"].ToString().Trim(); //Ftp用户口令
                objvPrjSite4DownLoadEN.UpdUserId = objRow["UpdUserId"].ToString().Trim(); //修改用户Id
                objvPrjSite4DownLoadEN.UpdDate = objRow["UpdDate"].ToString().Trim(); //UpdDate
                objvPrjSite4DownLoadEN.Memo = objRow["Memo"].ToString().Trim(); //备注
                arrObjList.Add(objvPrjSite4DownLoadEN);
            }
            objDT = null;
            return arrObjList;
        }

        public static bool IsExistRecordWs(string strCondition)
        {
            //检测记录是否存在
            vPrjSite4DownLoadServiceSoapClient objvPrjSite4DownLoadService = GetvPrjSite4DownLoadServiceSoapClient();
            bool bolIsExist = objvPrjSite4DownLoadService.vPrjSite4DownLoad_IsExistRecord(strCondition);
            return bolIsExist;
        }

        public static bool IsExistWs(string strPrjSiteId)
        {
            //检测记录是否存在
            vPrjSite4DownLoadServiceSoapClient objvPrjSite4DownLoadService = GetvPrjSite4DownLoadServiceSoapClient();
            bool bolIsExist = objvPrjSite4DownLoadService.vPrjSite4DownLoad_IsExist(strPrjSiteId);
            return bolIsExist;
        }
    }
