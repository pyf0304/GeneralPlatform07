        /// <summary>
        /// 根据关键字获取相关对象, 从缓存的对象列表中获取.
        /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecObjByKey_Cache)
        /// </summary>
        /// <param name = "lngmId">所给的关键字</param>
        /// <returns>根据关键字获取的对象</returns>
        public static clsUserMenusEN GetUserMenusObjBymId_Cache(long lngmId)
        {
            string strWhereCond = string.Format("1 = 1 order by mId");
            if (arrUserMenusObjLst_Cache == null)
            {
                arrUserMenusObjLst_Cache = clsUserMenusWS.GetUserMenusObjList(strWhereCond);
            }
            int intStart = 0;
            int intEnd = arrUserMenusObjLst_Cache.Count - 1;
            int intMid = 0;
            clsUserMenusEN objUserMenusEN = null;
            while (intEnd >= intStart)
            {
                intMid = (intStart + intEnd) / 2;
                objUserMenusEN = arrUserMenusObjLst_Cache[intMid];
                if (objUserMenusEN.mId == lngmId)
                {
                    intFindFailCount = 0;
                    return objUserMenusEN;
                }
                else if (objUserMenusEN.mId.CompareTo(lngmId) > 0)
                {
                    intEnd = intMid - 1;
                }
                else
                {
                    intStart = intMid + 1;
                }
            }
            intFindFailCount++;
            // 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
            arrUserMenusObjLst_Cache = null;
            if (intFindFailCount == 1) return GetUserMenusObjBymId_Cache(lngmId);
            string strErrMsgForGetObjById = string.Format("在UserMenus对象缓存列表中,找不到记录[mId = {0}][intFindFailCount = {1}](函数:GetUserMenusObjBymId_Cache)", lngmId, intFindFailCount);
            if (objUserMenusEN != null)
            {
                strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objUserMenusEN.mId, intMid);
            }
            else
            {
                strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
            }
            clsGeneralTab2.LogErrorS2("clsUserMenusBL", "GetUserMenusObjBymId_Cache", strErrMsgForGetObjById, "", "");
            throw new Exception(strErrMsgForGetObjById);
        }

        public static List<clsUserMenusEN> GetUserMenusObjList(string strWhereCond)
        {
            List<clsUserMenusEN> arrObjList = new List<clsUserMenusEN>();
            System.Data.DataTable objDT = null;
            objDT = GetDataTable_UserMenusWs(strWhereCond);
            if (objDT.Rows.Count == 0)
            {
                objDT = null;
                return arrObjList;
            }
            foreach (DataRow objRow in objDT.Rows)
            {
                clsUserMenusEN objUserMenusEN = new clsUserMenusEN();
                objUserMenusEN.mId = Int32.Parse(objRow["mId"].ToString().Trim()); //流水号
                objUserMenusEN.UserId = objRow["UserId"].ToString().Trim(); //用户ID
                objUserMenusEN.PrjId = objRow["PrjId"].ToString().Trim(); //项目Id
                objUserMenusEN.IsUseRoleMenu = com.taishsoft.common.clsTranslate.TransNullToBool_S(objRow["IsUseRoleMenu"].ToString().Trim()); //是否使用角色菜单
                objUserMenusEN.Memo = objRow["Memo"].ToString().Trim(); //备注
                arrObjList.Add(objUserMenusEN);
            }
            objDT = null;
            return arrObjList;
        }

