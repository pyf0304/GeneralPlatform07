        public static bool UpdateBySql2Ws(clsUserMenusEN objUserMenusEN)
        {
            UserMenusServiceSoapClient objUserMenusService = GetUserMenusServiceSoapClient();
            try
            {
                bool bolResult = objUserMenusService.UserMenus_UpdateBySql2(objUserMenusEN);
                return bolResult;
            }
            catch (Exception objException)
            {
                string strMsg = string.Format("执行WebService功能出错。文件地址:{0},函数名:{1}. 调用函数名:{2}.",
                     GetServiceUrl(), "UserMenus_UpdateBySql2", "clsUserMenusWS:UpdateBySql2Ws", objException.Message);
                strMsg += string.Format("出错信息:{0}",
                     objException.Message);
                throw new Exception(strMsg);
            }
        }

