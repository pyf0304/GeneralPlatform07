 ///生成绑定ListView的代码
 /// <summary>
 /// 函数功能:根据界面上查询控件中所设置内容查询表记录,
 ///			 并显示在ListView中。
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_BindListView)
 /// </summary>
public static int BindLv_QxUserMenuDetail(System.Windows.Forms.ListView lvQxUserMenuDetail, string strWhereCond)
{
//操作步骤:(共4步)
//	1、组合界面条件串；
//	2、根据条件串获取该表满足条件的DataTable；
//	3、设置ListView的列头信息
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
//		在本界面中是把状态显示在控件lblRecCount中。

System.Windows.Forms.ListViewItem lviQxUserMenuDetail; 
List<clsQxUserMenuDetailEN> arrQxUserMenuDetailObjList;
//	2、根据条件串获取该表满足条件的DataTable；
arrQxUserMenuDetailObjList = GetQxUserMenuDetailObjList(strWhereCond);
//	3、设置ListView的列头信息
lvQxUserMenuDetail.Items.Clear();//清除原来所有Item
lvQxUserMenuDetail.Columns.Clear();//清除原来所有列头信息
lvQxUserMenuDetail.Columns.Add("流水号", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxUserMenuDetail.Columns.Add("菜单Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxUserMenuDetail.Columns.Add("菜单名", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxUserMenuDetail.Columns.Add("是否显示", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxUserMenuDetail.Columns.Add("上级菜单Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxUserMenuDetail.Columns.Add("链接文件", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxUserMenuDetail.Columns.Add("图像文件", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxUserMenuDetail.Columns.Add("是否定制菜单", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxUserMenuDetail.Columns.Add("用户ID", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxUserMenuDetail.Columns.Add("项目Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxUserMenuDetail.Columns.Add("排序号", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxUserMenuDetail.Columns.Add("备注", 100, System.Windows.Forms.HorizontalAlignment.Left);
lvQxUserMenuDetail.View = System.Windows.Forms.View.Details;
//	4、设置ListView的Item信息。即把所有记录显示在ListView中
foreach (clsQxUserMenuDetailEN objQxUserMenuDetailEN in arrQxUserMenuDetailObjList)
{
lviQxUserMenuDetail = new System.Windows.Forms.ListViewItem();
lviQxUserMenuDetail.Tag = objQxUserMenuDetailEN.mId;
lviQxUserMenuDetail.Text = objQxUserMenuDetailEN.mId.ToString();
lviQxUserMenuDetail.SubItems.Add(objQxUserMenuDetailEN.MenuName);
lviQxUserMenuDetail.SubItems.Add(objQxUserMenuDetailEN.IsDisp.ToString());
lviQxUserMenuDetail.SubItems.Add(objQxUserMenuDetailEN.UpMenuId);
lviQxUserMenuDetail.SubItems.Add(objQxUserMenuDetailEN.LinkFile);
lviQxUserMenuDetail.SubItems.Add(objQxUserMenuDetailEN.ImgFile);
lviQxUserMenuDetail.SubItems.Add(objQxUserMenuDetailEN.IsCustomMenu.ToString());
lviQxUserMenuDetail.SubItems.Add(objQxUserMenuDetailEN.UserId);
lviQxUserMenuDetail.SubItems.Add(objQxUserMenuDetailEN.OrderNum.ToString());
lviQxUserMenuDetail.SubItems.Add(objQxUserMenuDetailEN.Memo);
lvQxUserMenuDetail.Items.Add(lviQxUserMenuDetail);
}
//	4、设置记录数的状态,
//		在本界面中是把状态显示在控件txtRecCount中。
return arrQxUserMenuDetailObjList.Count;
}

 /// <summary>
 /// 检查对象字段值是否合法,1)检查是否可空;2)检查字段值长度是否超长,如果出错就抛出错误.
 /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4WS_CheckPropertyNew)
 /// </summary>
public void CheckPropertyNew(clsQxUserMenuDetailEN objQxUserMenuDetailEN)
{
if (!Object.Equals(null, objQxUserMenuDetailEN.MenuId) && getStrLen(objQxUserMenuDetailEN.MenuId) > 8)
{
 throw new Exception("字段[菜单Id]的长度不能超过8!");
}
if (!Object.Equals(null, objQxUserMenuDetailEN.MenuName) && getStrLen(objQxUserMenuDetailEN.MenuName) > 50)
{
 throw new Exception("字段[菜单名]的长度不能超过50!");
}
if (!Object.Equals(null, objQxUserMenuDetailEN.UpMenuId) && getStrLen(objQxUserMenuDetailEN.UpMenuId) > 8)
{
 throw new Exception("字段[上级菜单Id]的长度不能超过8!");
}
if (!Object.Equals(null, objQxUserMenuDetailEN.LinkFile) && getStrLen(objQxUserMenuDetailEN.LinkFile) > 500)
{
 throw new Exception("字段[链接文件]的长度不能超过500!");
}
if (!Object.Equals(null, objQxUserMenuDetailEN.ImgFile) && getStrLen(objQxUserMenuDetailEN.ImgFile) > 300)
{
 throw new Exception("字段[图像文件]的长度不能超过300!");
}
if (!Object.Equals(null, objQxUserMenuDetailEN.UserId) && getStrLen(objQxUserMenuDetailEN.UserId) > 18)
{
 throw new Exception("字段[用户ID]的长度不能超过18!");
}
if (!Object.Equals(null, objQxUserMenuDetailEN.QxPrjId) && getStrLen(objQxUserMenuDetailEN.QxPrjId) > 4)
{
 throw new Exception("字段[项目Id]的长度不能超过4!");
}
if (!Object.Equals(null, objQxUserMenuDetailEN.Memo) && getStrLen(objQxUserMenuDetailEN.Memo) > 1000)
{
 throw new Exception("字段[备注]的长度不能超过1000!");
}
 objQxUserMenuDetailEN.IsCheckProperty = true;
 }

