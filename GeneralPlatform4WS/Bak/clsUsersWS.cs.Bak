        /// <summary>
        /// 根据关键字获取相关名称, 从缓存的对象列表中获取.
        /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecNameByKey_Cache)
        /// </summary>
        /// <param name = "strUserId">所给的关键字</param>
        /// <returns>根据关键字获取的名称</returns>
        public static string GetUserNameByUserId_Cache(string strUserId)
        {
            if (string.IsNullOrEmpty(strUserId) == true) return "";
            string strWhereCond = string.Format("1 = 1 order by UserId");
            if (arrUsersObjLst_Cache == null)
            {
                arrUsersObjLst_Cache = clsUsersWS.GetUsersObjList(strWhereCond);
            }
            int intStart = 0;
            int intEnd = arrUsersObjLst_Cache.Count - 1;
            int intMid = 0;
            clsUsersEN objUsersEN = null;
            while (intEnd >= intStart)
            {
                intMid = (intStart + intEnd) / 2;
                objUsersEN = arrUsersObjLst_Cache[intMid];
                if (objUsersEN.UserId == strUserId)
                {
                    intFindFailCount = 0;
                    return objUsersEN.UserName;
                }
                else if (objUsersEN.UserId.CompareTo(strUserId) > 0)
                {
                    intEnd = intMid - 1;
                }
                else
                {
                    intStart = intMid + 1;
                }
            }
            intFindFailCount++;
            // 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
            arrUsersObjLst_Cache = null;
            if (intFindFailCount == 1) return GetUserNameByUserId_Cache(strUserId);
            string strErrMsgForGetObjById = string.Format("在Users对象缓存列表中,找不到记录[UserId = {0}][intFindFailCount = {1}](函数:GetUserNameByUserId_Cache)", strUserId, intFindFailCount);
            if (objUsersEN != null)
            {
                strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objUsersEN.UserId, intMid);
            }
            else
            {
                strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
            }
            clsGeneralTab2.LogErrorS2("clsUsersBL", "GetUserNameByUserId_Cache", strErrMsgForGetObjById, "", "");
            throw new Exception(strErrMsgForGetObjById);
        }

        /// <summary>
        /// 根据关键字获取相关对象, 从缓存的对象列表中获取.
        /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetRecObjByKey_Cache)
        /// </summary>
        /// <param name = "strUserId">所给的关键字</param>
        /// <returns>根据关键字获取的对象</returns>
        public static clsUsersEN GetUsersObjByUserId_Cache(string strUserId)
        {
            if (string.IsNullOrEmpty(strUserId) == true) return null;
            string strWhereCond = string.Format("1 = 1 order by UserId");
            if (arrUsersObjLst_Cache == null)
            {
                arrUsersObjLst_Cache = clsUsersWS.GetUsersObjList(strWhereCond);
            }
            int intStart = 0;
            int intEnd = arrUsersObjLst_Cache.Count - 1;
            int intMid = 0;
            clsUsersEN objUsersEN = null;
            while (intEnd >= intStart)
            {
                intMid = (intStart + intEnd) / 2;
                objUsersEN = arrUsersObjLst_Cache[intMid];
                if (objUsersEN.UserId == strUserId)
                {
                    intFindFailCount = 0;
                    return objUsersEN;
                }
                else if (objUsersEN.UserId.CompareTo(strUserId) > 0)
                {
                    intEnd = intMid - 1;
                }
                else
                {
                    intStart = intMid + 1;
                }
            }
            intFindFailCount++;
            // 静态的对象列表,用于缓存,针对记录较少,作为参数表可以使用
            arrUsersObjLst_Cache = null;
            if (intFindFailCount == 1) return GetUsersObjByUserId_Cache(strUserId);
            string strErrMsgForGetObjById = string.Format("在Users对象缓存列表中,找不到记录[UserId = {0}][intFindFailCount = {1}](函数:GetUsersObjByUserId_Cache)", strUserId, intFindFailCount);
            if (objUsersEN != null)
            {
                strErrMsgForGetObjById += string.Format("最后一次查找的对象相关字段属性值:{0}.[intMid = {1}]", objUsersEN.UserId, intMid);
            }
            else
            {
                strErrMsgForGetObjById += string.Format("最后一次查找的对象为null, 请检查![intMid = {0}]", intMid);
            }
            clsGeneralTab2.LogErrorS2("clsUsersBL", "GetUsersObjByUserId_Cache", strErrMsgForGetObjById, "", "");
            throw new Exception(strErrMsgForGetObjById);
        }

        public static List<clsUsersEN> GetUsersObjList(string strWhereCond)
        {
            List<clsUsersEN> arrObjList = new List<clsUsersEN>();
            System.Data.DataTable objDT = null;
            objDT = GetDataTable_UsersWs(strWhereCond);
            if (objDT.Rows.Count == 0)
            {
                objDT = null;
                return arrObjList;
            }
            foreach (DataRow objRow in objDT.Rows)
            {
                clsUsersEN objUsersEN = new clsUsersEN();
                objUsersEN.UserId = objRow["UserId"].ToString().Trim(); //用户ID
                objUsersEN.UserName = objRow["UserName"].ToString().Trim(); //用户名
                objUsersEN.DepartmentId = objRow["DepartmentId"].ToString().Trim(); //部门Id
                objUsersEN.UserStateId = objRow["UserStateId"].ToString().Trim(); //用户状态Id
                objUsersEN.EffectiveDate = objRow["EffectiveDate"].ToString().Trim(); //有效日期
                objUsersEN.Password = objRow["Password"].ToString().Trim(); //口令
                objUsersEN.UpdDate = objRow["UpdDate"].ToString().Trim(); //修改日期
                objUsersEN.UpdUser = objRow["UpdUser"].ToString().Trim(); //修改用户
                objUsersEN.Memo = objRow["Memo"].ToString().Trim(); //备注
                arrObjList.Add(objUsersEN);
            }
            objDT = null;
            return arrObjList;
        }

        public static List<clsUsersEN> GetUsersObjListByRange(string strWhereCond, long lngMinNum, long lngMaxNum)
        {
            List<clsUsersEN> arrObjList = new List<clsUsersEN>();
            System.Data.DataTable objDT = null;
            objDT = GetDataTable_UsersByRangeWs(strWhereCond, lngMinNum, lngMaxNum);
            if (objDT.Rows.Count == 0)
            {
                objDT = null;
                return arrObjList;
            }
            foreach (DataRow objRow in objDT.Rows)
            {
                clsUsersEN objUsersEN = new clsUsersEN();
                objUsersEN.UserId = objRow["UserId"].ToString().Trim(); //用户ID
                objUsersEN.UserName = objRow["UserName"].ToString().Trim(); //用户名
                objUsersEN.DepartmentId = objRow["DepartmentId"].ToString().Trim(); //部门Id
                objUsersEN.UserStateId = objRow["UserStateId"].ToString().Trim(); //用户状态Id
                objUsersEN.EffectiveDate = objRow["EffectiveDate"].ToString().Trim(); //有效日期
                objUsersEN.Password = objRow["Password"].ToString().Trim(); //口令
                objUsersEN.UpdDate = objRow["UpdDate"].ToString().Trim(); //修改日期
                objUsersEN.UpdUser = objRow["UpdUser"].ToString().Trim(); //修改用户
                objUsersEN.Memo = objRow["Memo"].ToString().Trim(); //备注
                arrObjList.Add(objUsersEN);
            }
            objDT = null;
            return arrObjList;
        }

        public static bool DelRecordWs(string strUserId)
        {
            UsersServiceSoapClient objUsersService = GetUsersServiceSoapClient();
            try
            {
                bool bolResult = objUsersService.Users_DelRecord(strUserId);
                return bolResult;
            }
            catch (Exception objException)
            {
                string strMsg = string.Format("执行WebService功能出错。文件地址:{0},函数名:{1}. 调用函数名:{2}.",
                     GetServiceUrl(), "Users_DelRecord", "clsUsersWS:DelRecordWs", objException.Message);
                strMsg += string.Format("出错信息:{0}",
                     objException.Message);
                throw new Exception(strMsg);
            }
        }

