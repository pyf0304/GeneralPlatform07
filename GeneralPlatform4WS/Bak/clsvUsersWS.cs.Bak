        /// <summary>
        /// 
        /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:A_GenWebServiceTransCode4View)
        /// </summary>
        /// <returns></returns>
        public static vUsersServiceSoapClient GetvUsersServiceSoapClient()
        {
            if (objvUsersServiceSoapClient == null)
            {
                BasicHttpBinding binding = new BasicHttpBinding();
                binding.Name = "vUsersServiceSoap";
                binding.CloseTimeout = new System.TimeSpan(6000);
                binding.MaxReceivedMessageSize = 2147483647;
                String strServiceUrl = String.Empty;
                if (clsSysPara4WS.bolIsLocalHost == false)
                {
                    strServiceUrl = String.Format("http://{0}/{1}/vUsersService.asmx", clsSysPara4WS.strCurrIPAddressAndPort, clsSysPara4WS.strCurrPrx);
                }
                else
                {
                    strServiceUrl = String.Format("http://{0}/vUsersService.asmx", clsSysPara4WS.strCurrIPAddressAndPort_Local);
                }
                EndpointAddress address = new EndpointAddress(strServiceUrl);
                return new vUsersServiceSoapClient(binding, address);
            }
            else
            {
                return objvUsersServiceSoapClient;
            }
        }

        public clsvUsersWS()
        {
        }



        ///生成绑定ListView的代码
        /// <summary>
        /// 函数功能:根据界面上查询控件中所设置内容查询表记录,
        ///			 并显示在ListView中。
        /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:GenBindListView)
        /// </summary>
        public static int BindLv_vUsers(System.Windows.Forms.ListView lvvUsers, string strWhereCond)
        {
            //操作步骤:(共4步)
            //	1、组合界面条件串；
            //	2、根据条件串获取该表满足条件的DataTable；
            //	3、设置ListView的列头信息
            //	4、设置ListView的Item信息。即把所有记录显示在ListView中
            //		在本界面中是把状态显示在控件lblRecCount中。

            System.Windows.Forms.ListViewItem lvivUsers;
            List<clsvUsersEN> arrvUsersObjList;
            //	2、根据条件串获取该表满足条件的DataTable；
            arrvUsersObjList = GetvUsersObjList(strWhereCond);
            //	3、设置ListView的列头信息
            lvvUsers.Items.Clear();//清除原来所有Item
            lvvUsers.Columns.Clear();//清除原来所有列头信息
            lvvUsers.Columns.Add("用户ID", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("用户名", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("部门Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("部门名", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("所属部门号", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("名称缩写", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("上级部门", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("学科类型", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("部门类型ID", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("部门类型名", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("用户状态Id", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("用户状态名", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("有效日期", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("备注", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("修改日期", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.Columns.Add("修改用户", 100, System.Windows.Forms.HorizontalAlignment.Left);
            lvvUsers.View = System.Windows.Forms.View.Details;
            //	4、设置ListView的Item信息。即把所有记录显示在ListView中
            foreach (clsvUsersEN objvUsersEN in arrvUsersObjList)
            {
                lvivUsers = new System.Windows.Forms.ListViewItem();
                lvivUsers.Tag = objvUsersEN.UserId;
                lvivUsers.Text = objvUsersEN.UserId.ToString();
                lvivUsers.SubItems.Add(objvUsersEN.UserName);
                lvivUsers.SubItems.Add(objvUsersEN.DepartmentId);
                lvivUsers.SubItems.Add(objvUsersEN.DepartmentName);
                lvivUsers.SubItems.Add(objvUsersEN.UpDepartmentId);
                lvivUsers.SubItems.Add(objvUsersEN.DepartmentAbbrName);
                lvivUsers.SubItems.Add(objvUsersEN.UpDepartmentName);
                lvivUsers.SubItems.Add(objvUsersEN.SubjectTypeName);
                lvivUsers.SubItems.Add(objvUsersEN.DepartmentTypeId);
                lvivUsers.SubItems.Add(objvUsersEN.DepartmentTypeName);
                lvivUsers.SubItems.Add(objvUsersEN.UserStateId);
                lvivUsers.SubItems.Add(objvUsersEN.UserStateName);
                lvivUsers.SubItems.Add(objvUsersEN.EffectiveDate);
                lvivUsers.SubItems.Add(objvUsersEN.Memo);
                lvivUsers.SubItems.Add(objvUsersEN.UpdDate);
                lvivUsers.SubItems.Add(objvUsersEN.UpdUser);
                lvvUsers.Items.Add(lvivUsers);
            }
            //	4、设置记录数的状态,
            //		在本界面中是把状态显示在控件txtRecCount中。
            return arrvUsersObjList.Count;
        }

        /// <summary>
        /// 根据条件获取数据表,用DataTable表示
        /// (AGC_CSV7.BusinessLogicEx.AutoGC6Cs_WS:Gen_4Ws_GetDataTable4Tab)
        /// </summary>
        /// <param name = "strWhereCond">条件串</param>
        /// <returns>返回满足条件一定范围的DataTable</returns>
        public static DataTable GetDataTable_vUsersWs(string strWhereCond)
        {
            vUsersServiceSoapClient objvUsersService = GetvUsersServiceSoapClient();
            DataSet objDS = null;
            try
            {
                objDS = objvUsersService.vUsers_GetDataSet(strWhereCond);
                DataTable objDT = objDS.Tables[0];
                return objDT;
            }
            catch (Exception objException)
            {
                string strMsg = string.Format("执行WebService功能出错。文件地址:{0},函数名:{1}. 调用函数名:{2}.",
                     GetServiceUrl(), "vUsers_GetDataSet", "clsvUsersWS:GetDataTable_vUsersWs", objException.Message);
                strMsg += string.Format("出错信息:{0}",
                     objException.Message);
                throw new Exception(strMsg);
            }
        }

