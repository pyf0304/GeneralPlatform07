                throw new Exception("获取表View数据出错！\r\n" + objException.Message);
            }
        }
        /// <summary>
        /// 
        /// </summary>
        /// <param name="objSubjectRelation"></param>
        /// <returns></returns>
        public static bool GetSubjectRelationWs(ref clsSubjectRelationEN objSubjectRelation)
        {
            SubjectRelationServiceSoapClient objSubjectRelationService = GetSubjectRelationServiceSoapClient();
            bool bolResult = objSubjectRelationService.SubjectRelation_GetSubjectRelation(ref objSubjectRelation);
            return bolResult;
        }
        /// <summary>
        /// 
        /// </summary>
        /// <param name="strCondition"></param>
        /// <returns></returns>
        public static List<clsSubjectRelationEN> GetSubjectRelationObjList(string strCondition)
        {
            List<clsSubjectRelationEN> arrObjList = new List<clsSubjectRelationEN>();
            System.Data.DataTable objDT = null;
            objDT = GetDataTable_SubjectRelationWs(strCondition);
            if (objDT.Rows.Count == 0)
            {
                objDT = null;
                return arrObjList;
            }
            foreach (DataRow objRow in objDT.Rows)
            {
                clsSubjectRelationEN objSubjectRelation = new clsSubjectRelationEN();
                objSubjectRelation.mId = Int32.Parse(objRow["mId"].ToString().Trim()); //流水号
                objSubjectRelation.UserId = objRow["UserId"].ToString().Trim(); //用户ID
                objSubjectRelation.LeaderId = objRow["LeaderId"].ToString().Trim(); //领导Id
                objSubjectRelation.IsDirectLeader = com.taishsoft.commdb.clsGeneralTab.TransNullToBool_S(objRow["IsDirectLeader"].ToString().Trim()); //是否直接领导
                objSubjectRelation.Memo = objRow["Memo"].ToString().Trim(); //备注

                arrObjList.Add(objSubjectRelation);
            }
            objDT = null;
            return arrObjList;
        }
        /// <summary>
        /// 
        /// </summary>
        /// <param name="lngmId"></param>
        /// <returns></returns>
        public static bool DelRecordWs(long lngmId)
        {
            SubjectRelationServiceSoapClient objSubjectRelationService = GetSubjectRelationServiceSoapClient();
            try
            {
                bool bolResult = objSubjectRelationService.SubjectRelation_DelRecord(lngmId);
                return bolResult;
            }
            catch (Exception objException)
            {
                throw new Exception("删除记录出错！\r\n" + objException.Message);
            }
        }
        /// <summary>
        /// 
        /// </summary>
        /// <param name="arrStdId"></param>
        /// <returns></returns>
        public static bool DelSubjectRelationsWs(List<string>  arrStdId)
        {
            SubjectRelationServiceSoapClient objSubjectRelationService = GetSubjectRelationServiceSoapClient();
            try
            {
                string[] slngmId = (string[])(arrStdId.ToArray());
                bool bolResult = objSubjectRelationService.SubjectRelation_DelSubjectRelations(slngmId);
                return bolResult;
            }
            catch (Exception objException)
            {
                throw new Exception("删除记录出错！\r\n" + objException.Message);
            }
        }
